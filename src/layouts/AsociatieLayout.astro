---
import PortalTopBar from '@/components/PortalTopBar.astro';
import { getVisiblePortals } from '@/lib/portals';

interface Props {
  title: string;
  user: any;
  section?: string;
}

const { title, user, section = 'Asociație' } = Astro.props;
const hasPortalBar = user ? getVisiblePortals(user.role).length >= 2 : false;

const navItems = [
  { href: '/asociatie-admin', icon: '🏠', label: 'Dashboard' },
  { href: '/asociatie-admin/cluburi', icon: '🏛️', label: 'Cluburi' },
  { href: '/asociatie-admin/legitimari', icon: '📜', label: 'Legitimări' },
  { href: '/asociatie-admin/transferuri', icon: '🔄', label: 'Transferuri' },
  { href: '/asociatie-admin/competitii', icon: '🥇', label: 'Competiții' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Portal Asociație</title>
  <link rel="icon" type="image/svg+xml" href="/branding/sporthub-favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --aso-bg: #431407;
      --aso-text: #fcd9b0;
      --aso-active: #ffffff;
      --aso-accent: #f97316;
      --aso-border: #6b2408;
      --content-bg: #f1f5f9;
      --font-brand: 'Outfit', system-ui, sans-serif;
      --font-ui: 'Inter', system-ui, sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-ui), -apple-system, BlinkMacSystemFont, sans-serif; display: flex; min-height: 100vh; background: var(--content-bg); }

    /* SIDEBAR */
    #sidebar {
      width: 248px; height: 100vh; background: var(--aso-bg);
      display: flex; flex-direction: column; position: fixed; top: 0; left: 0; z-index: 100;
      transition: transform .25s ease;
    }
    .sidebar-logo {
      padding: 24px 16px; border-bottom: 1px solid rgba(255,255,255,.12);
      display: flex; align-items: center; gap: 12px; flex-shrink: 0;
    }
    .logo-icon { font-size: 32px; }
    .brand-name { color: #fff; font-size: 15px; font-weight: 700; line-height: 1.3; }
    .brand-sub { color: var(--aso-accent); font-size: 10px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; margin-top: 4px; }

    nav { flex: 1; padding: 16px 0; overflow-y: auto; min-height: 0; scrollbar-width: thin; scrollbar-color: rgba(255,255,255,.1) transparent; }
    nav::-webkit-scrollbar { width: 6px; }
    nav::-webkit-scrollbar-track { background: transparent; }
    nav::-webkit-scrollbar-thumb { background: rgba(255,255,255,.2); border-radius: 3px; }

    .nav-item {
      display: flex; align-items: center; gap: 12px;
      padding: 12px 18px; color: var(--aso-text);
      text-decoration: none; font-size: 14px; font-weight: 500;
      border-radius: 8px; margin: 3px 12px;
      transition: all .2s ease;
    }
    .nav-item:hover { background: rgba(255,255,255,.1); color: #fff; }
    .nav-item.active { background: var(--aso-accent); color: #fff; font-weight: 600; box-shadow: 0 4px 12px rgba(249,115,22,.3); }
    .nav-icon { width: 20px; text-align: center; font-size: 18px; }

    .nav-section {
      padding: 12px 18px 6px;
      font-size: 10px; font-weight: 700; letter-spacing: .08em;
      text-transform: uppercase; color: #a16207;
    }

    .sidebar-footer { padding: 16px; border-top: 1px solid rgba(255,255,255,.12); flex-shrink: 0; }

    /* MAIN */
    #main { margin-left: 248px; flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

    /* TOPBAR */
    #topbar {
      background: #fff; padding: 0 32px; height: 64px;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 2px solid #e2e8f0; position: sticky; top: 0; z-index: 90;
      box-shadow: 0 2px 4px rgba(0,0,0,.05);
    }
    .page-title { font-family: var(--font-brand); font-size: 18px; font-weight: 700; color: #1e293b; letter-spacing: -.5px; }
    .topbar-right { display: flex; align-items: center; gap: 16px; }
    .user-badge { display: flex; align-items: center; gap: 10px; font-size: 13px; color: #475569; padding: 8px 12px; background: #f1f5f9; border-radius: 8px; }
    .user-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: var(--aso-bg); color: var(--aso-accent);
      display: flex; align-items: center; justify-content: center;
      font-size: 14px; font-weight: 700;
    }
    .aso-badge {
      background: var(--aso-accent); color: #fff;
      font-size: 11px; font-weight: 700;
      padding: 4px 12px; border-radius: 8px;
      letter-spacing: .05em;
    }

    /* CONTENT */
    #content { flex: 1; padding: 32px 40px; max-width: 1600px; }

    /* Buttons */
    .btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 12px 24px; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; border: none; text-decoration: none; transition: all .2s ease; white-space: nowrap; }
    .btn:hover { transform: translateY(-2px); box-shadow: 0 8px 16px rgba(0,0,0,.1); }
    .btn:active { transform: translateY(0); }
    .btn-accent { background: var(--aso-accent); color: #fff; font-weight: 600; }
    .btn-accent:hover { background: #ea580c; }
    .btn-outline { background: #fff; color: #374151; border: 2px solid #d1d5db; }
    .btn-outline:hover { background: #f1f5f9; }
    .btn-sm { padding: 8px 16px; font-size: 13px; }
    .btn-lg { padding: 14px 32px; font-size: 15px; }

    .card { background: #fff; border-radius: 12px; box-shadow: 0 1px 3px rgba(0,0,0,.08); padding: 28px; margin-bottom: 24px; border: 1px solid #e2e8f0; }
    .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid #e2e8f0; }
    .card-title { font-family: var(--font-brand); font-size: 16px; font-weight: 700; color: #1e293b; }

    .stat-card { background: #fff; border-radius: 10px; padding: 20px; box-shadow: 0 1px 4px rgba(0,0,0,.06); }
    .stat-value { font-family: var(--font-brand); font-size: 28px; font-weight: 700; color: #431407; }
    .stat-label { font-size: 12px; color: #64748b; margin-top: 4px; }

    .table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
    .table th { padding: 10px 12px; text-align: left; font-size: 11px; font-weight: 600; letter-spacing: .05em; text-transform: uppercase; color: #64748b; border-bottom: 2px solid #f1f5f9; }
    .table td { padding: 11px 12px; border-bottom: 1px solid #f8fafc; color: #374151; vertical-align: middle; }
    .table tr:hover td { background: #f8fafc; }

    .badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 9px; border-radius: 12px; font-size: 11px; font-weight: 600; }
    .badge-green { background: #dcfce7; color: #166534; }
    .badge-yellow { background: #fef9c3; color: #854d0e; }
    .badge-red { background: #fee2e2; color: #991b1b; }
    .badge-blue { background: #dbeafe; color: #1d4ed8; }
    .badge-gray { background: #f1f5f9; color: #475569; }

    .form-group { margin-bottom: 24px; }
    .form-label { display: block; font-size: 13px; font-weight: 700; color: #1e293b; margin-bottom: 8px; text-transform: uppercase; letter-spacing: .05em; }
    .form-input, .form-select, .form-textarea {
      width: 100%; padding: 12px 16px; border: 2px solid #e2e8f0;
      border-radius: 8px; font-size: 14px; outline: none; transition: all .2s;
      font-family: inherit; background: #fff;
    }
    .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--aso-accent); box-shadow: 0 0 0 3px rgba(249,115,22,.1); background: #fff; }
    .form-input::placeholder { color: #94a3b8; }

    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 200; align-items: center; justify-content: center; padding: 20px; }
    .modal-overlay.open { display: flex; }
    .modal { background: #fff; border-radius: 12px; width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto; }
    .modal-header { display: flex; align-items: center; justify-content: space-between; padding: 18px 24px; border-bottom: 1px solid #f1f5f9; }
    .modal-title { font-size: 16px; font-weight: 600; color: #1e293b; }
    .modal-close { background: none; border: none; font-size: 20px; cursor: pointer; color: #64748b; }
    .modal-body { padding: 20px 24px; }
    .modal-footer { padding: 16px 24px; border-top: 1px solid #f1f5f9; display: flex; justify-content: flex-end; gap: 8px; }

    .alert { padding: 12px 16px; border-radius: 8px; font-size: 13.5px; margin-bottom: 16px; }
    .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; }
    .alert-warning { background: #fffbeb; border: 1px solid #fde68a; color: #92400e; }

    /* Portal bar offset */
    body.has-portal-bar { padding-top: 40px; }
    body.has-portal-bar #sidebar { top: 40px; height: calc(100vh - 40px); }
    body.has-portal-bar #topbar { top: 40px; }

    /* Mobile */
    #menu-toggle { display: none; background: none; border: none; font-size: 22px; cursor: pointer; padding: 4px 8px; }
    #sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 99; }
    @media (max-width: 900px) {
      #sidebar { transform: translateX(-100%); }
      #sidebar.open { transform: translateX(0); }
      #sidebar.open + #sidebar-overlay { display: block; }
      #main { margin-left: 0; }
      #menu-toggle { display: block; }
      #content { padding: 16px; }
      body.has-portal-bar #sidebar { top: 40px; height: calc(100vh - 40px); }
    }
  </style>
</head>
<body class={hasPortalBar ? 'has-portal-bar' : ''}>

<PortalTopBar user={user ?? null} />

<aside id="sidebar">
  <div class="sidebar-logo">
    <div>
      <img src="/branding/sporthub-logo-white.svg" alt="SportHub" style="height:32px;margin-bottom:4px" />
      <div class="brand-sub">{user?.association_name ?? section}</div>
    </div>
  </div>

  <nav>
    <div class="nav-section">Administrație</div>
    {navItems.map(item => (
      <a
        href={item.href}
        class={`nav-item${currentPath === item.href || (item.href !== '/asociatie-admin' && currentPath.startsWith(item.href)) ? ' active' : ''}`}
      >
        <span class="nav-icon">{item.icon}</span>
        {item.label}
      </a>
    ))}
  </nav>

  <div class="sidebar-footer">
    <form method="POST" action="/api/auth/logout" style="margin:0">
      <button type="submit" style="background:none;border:none;cursor:pointer;color:#fcd9b0;font-size:13px;display:flex;align-items:center;gap:8px;padding:6px 0;width:100%">
        🚪 Ieșire
      </button>
    </form>
  </div>
</aside>

<div id="sidebar-overlay" onclick="document.getElementById('sidebar').classList.remove('open')"></div>

<div id="main">
  <header id="topbar">
    <div style="display:flex;align-items:center;gap:12px">
      <button id="menu-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">☰</button>
      <span class="page-title">{title}</span>
    </div>
    <div class="topbar-right">
      <span class="aso-badge">ASOCIAȚIE</span>
      {user && (
        <div class="user-badge">
          <div class="user-avatar">
            {(user.first_name?.[0] ?? user.email?.[0] ?? 'A').toUpperCase()}
          </div>
          <span>{user.first_name ?? user.email}</span>
        </div>
      )}
    </div>
  </header>

  <main id="content">
    <slot />
  </main>
</div>

</body>
</html>
