---
import type { SessionUser } from '@/lib/auth';
import PortalTopBar from '@/components/PortalTopBar.astro';
import { getVisiblePortals } from '@/lib/portals';

interface Props {
  title: string;
  user?: SessionUser | null;
  section?: string;
}

const { title, user, section = 'CCLTC' } = Astro.props;
const hasPortalBar = user ? getVisiblePortals(user.role).length >= 2 : false;

const navItems = [
  { href: '/federatie-admin', icon: '📊', label: 'Dashboard' },
  { href: '/federatie-admin/legitimari', icon: '🪪', label: 'Legitimări' },
  { href: '/federatie-admin/transferuri', icon: '🔄', label: 'Transferuri' },
  { href: '/federatie-admin/cereri', icon: '📬', label: 'Cereri Cluburi' },
  { href: '/federatie-admin/suspendari', icon: '🚫', label: 'Suspendări' },
  { href: '/federatie-admin/competitii', icon: '🥇', label: 'Competiții' },
  { href: '/federatie-admin/arbitri', icon: '👔', label: 'Arbitri' },
  { href: '/federatie-admin/nationala', icon: '🇷🇴', label: 'Echipe Naționale' },
  { href: '/federatie-admin/jucatori', icon: '👤', label: 'Jucători' },
  { href: '/federatie-admin/cluburi', icon: '🏟️', label: 'Cluburi' },
  { href: '/federatie-admin/anunturi', icon: '📢', label: 'Anunțuri' },
  { href: '/federatie-admin/rapoarte', icon: '📈', label: 'Rapoarte' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Portal FRBS</title>
  <style>
    :root {
      --fed-bg: #001524;
      --fed-text: #94a3b8;
      --fed-active: #ffffff;
      --fed-accent: #F4B400;
      --fed-border: #0a2540;
      --content-bg: #f1f5f9;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; display: flex; min-height: 100vh; background: var(--content-bg); }

    /* SIDEBAR */
    #sidebar {
      width: 248px; min-height: 100vh; background: var(--fed-bg);
      display: flex; flex-direction: column; position: fixed; top: 0; left: 0; z-index: 100;
      transition: transform .25s ease;
    }
    .sidebar-logo {
      padding: 18px 16px 14px; border-bottom: 1px solid var(--fed-border);
      display: flex; align-items: center; gap: 10px;
    }
    .logo-icon { font-size: 28px; }
    .brand-name { color: #fff; font-size: 14px; font-weight: 700; line-height: 1.3; }
    .brand-sub { color: var(--fed-accent); font-size: 11px; font-weight: 600; letter-spacing: .05em; text-transform: uppercase; }

    nav { flex: 1; padding: 10px 0; overflow-y: auto; }
    .nav-item {
      display: flex; align-items: center; gap: 10px;
      padding: 9px 16px; color: var(--fed-text);
      text-decoration: none; font-size: 13.5px; border-radius: 6px; margin: 1px 8px;
      transition: background .15s, color .15s;
    }
    .nav-item:hover { background: #0a2540; color: #e2e8f0; }
    .nav-item.active { background: var(--fed-accent); color: #001524; font-weight: 600; }
    .nav-icon { width: 20px; text-align: center; font-size: 15px; }

    .nav-section {
      padding: 10px 16px 4px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: #3d5a7a;
    }

    .sidebar-footer { padding: 12px 16px; border-top: 1px solid var(--fed-border); }
    .sidebar-footer a { color: #4a7a9b; font-size: 13px; text-decoration: none; display: flex; align-items: center; gap: 8px; padding: 6px 0; }
    .sidebar-footer a:hover { color: #94a3b8; }

    /* MAIN */
    #main { margin-left: 248px; flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

    /* TOPBAR */
    #topbar {
      background: #fff; padding: 0 24px; height: 54px;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid #e2e8f0; position: sticky; top: 0; z-index: 90;
    }
    .page-title { font-size: 15px; font-weight: 600; color: #1e293b; }
    .topbar-right { display: flex; align-items: center; gap: 12px; }
    .user-badge { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #475569; }
    .user-avatar {
      width: 30px; height: 30px; border-radius: 50%;
      background: var(--fed-bg); color: var(--fed-accent);
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700;
    }
    .fed-badge {
      background: #F4B400; color: #001524;
      font-size: 10px; font-weight: 700;
      padding: 2px 8px; border-radius: 10px;
      letter-spacing: .04em;
    }

    /* CONTENT */
    #content { flex: 1; padding: 24px; }

    /* Utility classes reutilizate în toate paginile federație */
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 7px; font-size: 13.5px; font-weight: 500; cursor: pointer; border: none; text-decoration: none; transition: opacity .15s; }
    .btn:hover { opacity: .85; }
    .btn-primary { background: var(--fed-bg); color: #fff; }
    .btn-gold { background: var(--fed-accent); color: var(--fed-bg); font-weight: 600; }
    .btn-danger { background: #ef4444; color: #fff; }
    .btn-outline { background: #fff; color: #374151; border: 1.5px solid #d1d5db; }
    .btn-sm { padding: 5px 10px; font-size: 12px; }

    .card { background: #fff; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,.06); padding: 20px 24px; }
    .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .card-title { font-size: 15px; font-weight: 600; color: #1e293b; }

    .stat-card { background: #fff; border-radius: 10px; padding: 20px; box-shadow: 0 1px 4px rgba(0,0,0,.06); }
    .stat-value { font-size: 28px; font-weight: 700; color: #001524; }
    .stat-label { font-size: 12px; color: #64748b; margin-top: 4px; }

    .table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
    .table th { padding: 10px 12px; text-align: left; font-size: 11px; font-weight: 600; letter-spacing: .05em; text-transform: uppercase; color: #64748b; border-bottom: 2px solid #f1f5f9; }
    .table td { padding: 11px 12px; border-bottom: 1px solid #f8fafc; color: #374151; vertical-align: middle; }
    .table tr:hover td { background: #f8fafc; }

    .badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 9px; border-radius: 12px; font-size: 11px; font-weight: 600; }
    .badge-green { background: #dcfce7; color: #166534; }
    .badge-yellow { background: #fef9c3; color: #854d0e; }
    .badge-red { background: #fee2e2; color: #991b1b; }
    .badge-blue { background: #dbeafe; color: #1d4ed8; }
    .badge-gray { background: #f1f5f9; color: #475569; }
    .badge-gold { background: #fef3c7; color: #92400e; }

    .form-group { margin-bottom: 16px; }
    .form-label { display: block; font-size: 13px; font-weight: 500; color: #374151; margin-bottom: 5px; }
    .form-input, .form-select, .form-textarea {
      width: 100%; padding: 9px 12px; border: 1.5px solid #e2e8f0;
      border-radius: 7px; font-size: 14px; outline: none; transition: border-color .15s;
    }
    .form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--fed-bg); }

    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,21,.5); z-index: 200; align-items: center; justify-content: center; padding: 20px; }
    .modal-overlay.open { display: flex; }
    .modal { background: #fff; border-radius: 12px; width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto; }
    .modal-header { display: flex; align-items: center; justify-content: space-between; padding: 18px 24px; border-bottom: 1px solid #f1f5f9; }
    .modal-title { font-size: 16px; font-weight: 600; color: #1e293b; }
    .modal-close { background: none; border: none; font-size: 20px; cursor: pointer; color: #64748b; }
    .modal-body { padding: 20px 24px; }
    .modal-footer { padding: 16px 24px; border-top: 1px solid #f1f5f9; display: flex; justify-content: flex-end; gap: 8px; }

    .alert { padding: 12px 16px; border-radius: 8px; font-size: 13.5px; margin-bottom: 16px; }
    .alert-info { background: #eff6ff; border: 1px solid #bfdbfe; color: #1d4ed8; }
    .alert-warning { background: #fffbeb; border: 1px solid #fde68a; color: #92400e; }
    .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #166534; }
    .alert-error { background: #fef2f2; border: 1px solid #fecaca; color: #991b1b; }

    /* Portal bar offset */
    body.has-portal-bar { padding-top: 40px; }
    body.has-portal-bar #sidebar { top: 40px; min-height: calc(100vh - 40px); }
    body.has-portal-bar #topbar { top: 40px; }

    /* Mobile */
    #menu-toggle { display: none; background: none; border: none; font-size: 22px; cursor: pointer; }
    @media (max-width: 900px) {
      #sidebar { transform: translateX(-100%); }
      #sidebar.open { transform: translateX(0); }
      #main { margin-left: 0; }
      #menu-toggle { display: block; }
    }
  </style>
</head>
<body class={hasPortalBar ? 'has-portal-bar' : ''}>

<PortalTopBar user={user ?? null} />

<aside id="sidebar">
  <div class="sidebar-logo">
    <span class="logo-icon">⚾</span>
    <div>
      <div class="brand-name">FRBS</div>
      <div class="brand-sub">{section}</div>
    </div>
  </div>

  <nav>
    <div class="nav-section">Administrație</div>
    {navItems.slice(0, 5).map(item => (
      <a
        href={item.href}
        class={`nav-item${currentPath === item.href || (item.href !== '/federatie-admin' && currentPath.startsWith(item.href)) ? ' active' : ''}`}
      >
        <span class="nav-icon">{item.icon}</span>
        {item.label}
      </a>
    ))}
    <div class="nav-section">Competiții</div>
    {navItems.slice(5, 8).map(item => (
      <a
        href={item.href}
        class={`nav-item${currentPath === item.href || (item.href !== '/federatie-admin' && currentPath.startsWith(item.href)) ? ' active' : ''}`}
      >
        <span class="nav-icon">{item.icon}</span>
        {item.label}
      </a>
    ))}
    <div class="nav-section">Registre</div>
    {navItems.slice(8).map(item => (
      <a
        href={item.href}
        class={`nav-item${currentPath === item.href || (item.href !== '/federatie-admin' && currentPath.startsWith(item.href)) ? ' active' : ''}`}
      >
        <span class="nav-icon">{item.icon}</span>
        {item.label}
      </a>
    ))}
  </nav>

  <div class="sidebar-footer">
    <a href="/api/auth/logout">🚪 Deconectare</a>
  </div>
</aside>

<div id="main">
  <header id="topbar">
    <div style="display:flex;align-items:center;gap:12px">
      <button id="menu-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">☰</button>
      <span class="page-title">{title}</span>
    </div>
    <div class="topbar-right">
      <span class="fed-badge">PORTAL FRBS</span>
      {user && (
        <div class="user-badge">
          <div class="user-avatar">
            {(user.first_name?.[0] ?? user.email[0]).toUpperCase()}
          </div>
          <span>{user.first_name ?? user.email}</span>
        </div>
      )}
    </div>
  </header>

  <main id="content">
    <slot />
  </main>
</div>

</body>
</html>
