---
interface Props {
  title: string;
  user: any;
}

const { title, user } = Astro.props;

const navItems = [
  { href: '/player', icon: '🏠', label: 'Dashboard' },
  { href: '/player/attendance', icon: '📅', label: 'Prezențe' },
  { href: '/player/evaluations', icon: '⭐', label: 'Evaluări' },
  { href: '/player/medical', icon: '🏥', label: 'Medical' },
  { href: '/player/meciuri', icon: '⚾', label: 'Meciuri' },
];

const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — SportHub</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --pl-bg: #0f172a;
      --pl-accent: #3b82f6;
      --pl-text: #94a3b8;
      --pl-border: #1e293b;
      --content-bg: #f1f5f9;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', sans-serif; display: flex; min-height: 100vh; background: var(--content-bg); }

    #sidebar {
      width: 240px; min-height: 100vh; background: var(--pl-bg);
      display: flex; flex-direction: column; position: fixed; top: 0; left: 0; z-index: 100;
      transition: transform .25s ease;
    }
    .sidebar-logo {
      padding: 20px 16px; border-bottom: 1px solid var(--pl-border);
      display: flex; align-items: center; gap: 10px;
    }
    .logo-icon { font-size: 24px; }
    .brand { color: #fff; font-size: 18px; font-weight: 700; }
    .brand-sub { color: #64748b; font-size: 11px; text-transform: uppercase; letter-spacing: .05em; }

    nav { flex: 1; padding: 12px 0; overflow-y: auto; }
    .nav-item {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 16px; color: var(--pl-text);
      text-decoration: none; font-size: 14px; border-radius: 6px; margin: 2px 8px;
      transition: background .15s, color .15s;
    }
    .nav-item:hover { background: #1e293b; color: #e2e8f0; }
    .nav-item.active { background: var(--pl-accent); color: #fff; }
    .nav-icon { width: 20px; text-align: center; font-size: 16px; }

    .sidebar-footer { padding: 12px 16px; border-top: 1px solid var(--pl-border); }
    .sidebar-footer form { margin: 0; }
    .logout-btn {
      background: none; border: none; cursor: pointer;
      color: #64748b; font-size: 13px; display: flex; align-items: center; gap: 8px;
      padding: 6px 0; width: 100%; text-align: left; font-family: inherit;
    }
    .logout-btn:hover { color: #94a3b8; }

    #main { margin-left: 240px; flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

    #topbar {
      background: #fff; padding: 0 24px; height: 56px;
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid #e2e8f0; position: sticky; top: 0; z-index: 90;
    }
    .page-title { font-size: 16px; font-weight: 600; color: #1e293b; }
    .topbar-right { display: flex; align-items: center; gap: 12px; }
    .user-badge { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #475569; }
    .user-avatar {
      width: 32px; height: 32px; border-radius: 50%;
      background: var(--pl-accent); color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-size: 13px; font-weight: 600;
    }
    .role-badge {
      background: #dbeafe; color: #1d4ed8;
      font-size: 10px; font-weight: 700;
      padding: 2px 8px; border-radius: 10px;
    }

    #content { flex: 1; padding: 24px; }

    /* Utility classes */
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: 7px; font-size: 13.5px; font-weight: 500; cursor: pointer; border: none; text-decoration: none; transition: opacity .15s; }
    .btn:hover { opacity: .85; }
    .btn-primary { background: var(--pl-accent); color: #fff; }
    .btn-outline { background: #fff; color: #374151; border: 1.5px solid #d1d5db; }
    .btn-sm { padding: 5px 10px; font-size: 12px; }

    .card { background: #fff; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,.06); padding: 20px 24px; }
    .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
    .card-title { font-size: 15px; font-weight: 600; color: #1e293b; }

    .stat-card { background: #fff; border-radius: 10px; padding: 20px; box-shadow: 0 1px 4px rgba(0,0,0,.06); }
    .stat-value { font-size: 28px; font-weight: 700; color: var(--pl-bg); }
    .stat-label { font-size: 12px; color: #64748b; margin-top: 4px; }

    .table { width: 100%; border-collapse: collapse; font-size: 13.5px; }
    .table th { padding: 10px 12px; text-align: left; font-size: 11px; font-weight: 600; letter-spacing: .05em; text-transform: uppercase; color: #64748b; border-bottom: 2px solid #f1f5f9; }
    .table td { padding: 11px 12px; border-bottom: 1px solid #f8fafc; color: #374151; vertical-align: middle; }
    .table tr:hover td { background: #f8fafc; }

    .badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 9px; border-radius: 12px; font-size: 11px; font-weight: 600; }
    .badge-green { background: #dcfce7; color: #166534; }
    .badge-yellow { background: #fef9c3; color: #854d0e; }
    .badge-red { background: #fee2e2; color: #991b1b; }
    .badge-blue { background: #dbeafe; color: #1d4ed8; }
    .badge-gray { background: #f1f5f9; color: #475569; }

    .alert { padding: 12px 16px; border-radius: 8px; font-size: 13.5px; margin-bottom: 16px; }
    .alert-info { background: #eff6ff; border: 1px solid #bfdbfe; color: #1d4ed8; }
    .alert-warning { background: #fffbeb; border: 1px solid #fde68a; color: #92400e; }

    #menu-toggle { display: none; background: none; border: none; font-size: 22px; cursor: pointer; }
    @media (max-width: 768px) {
      #sidebar { transform: translateX(-100%); }
      #sidebar.open { transform: translateX(0); }
      #main { margin-left: 0; }
      #menu-toggle { display: block; }
    }
  </style>
</head>
<body>

<aside id="sidebar">
  <div class="sidebar-logo">
    <span class="logo-icon">⚽</span>
    <div>
      <div class="brand">SportHub</div>
      <div class="brand-sub">Portal Jucător</div>
    </div>
  </div>

  <nav>
    {navItems.map(item => (
      <a
        href={item.href}
        class={`nav-item${currentPath === item.href || (item.href !== '/player' && currentPath.startsWith(item.href)) ? ' active' : ''}`}
      >
        <span class="nav-icon">{item.icon}</span>
        {item.label}
      </a>
    ))}
  </nav>

  <div class="sidebar-footer">
    <form method="POST" action="/api/auth/logout">
      <button type="submit" class="logout-btn">🚪 Ieșire</button>
    </form>
  </div>
</aside>

<div id="main">
  <header id="topbar">
    <div style="display:flex;align-items:center;gap:12px">
      <button id="menu-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">☰</button>
      <span class="page-title">{title}</span>
    </div>
    <div class="topbar-right">
      <span class="role-badge">JUCĂTOR</span>
      {user && (
        <div class="user-badge">
          <div class="user-avatar">
            {(user.first_name?.[0] ?? user.email?.[0] ?? 'J').toUpperCase()}
          </div>
          <span>{user.first_name ?? user.email}</span>
        </div>
      )}
    </div>
  </header>

  <main id="content">
    <slot />
  </main>
</div>

</body>
</html>
