    :root[data-theme="dark"] .content table { background: var(--bg-card) !important; }
    :root[data-theme="dark"] .content th { background: var(--bg-table-head) !important; color: var(--text-subtle) !important; }
    :root[data-theme="dark"] .content td { color: var(--text-primary) !important; border-color: var(--border-color-soft) !important; }
    /* Headers and text in dark mode */
    :root[data-theme="dark"] .content h1,
    :root[data-theme="dark"] .content h2,
    :root[data-theme="dark"] .content h3,
    :root[data-theme="dark"] .content h4 { color: var(--text-primary) !important; }
    :root[data-theme="dark"] .topbar h1 { color: var(--text-primary) !important; }
    /* Keep intentional status colors intact */
    :root[data-theme="dark"] .content [style*="color:#dc2626"],
    :root[data-theme="dark"] .content [style*="color:#16a34a"],
    :root[data-theme="dark"] .content [style*="color:#d97706"],
    :root[data-theme="dark"] .content [style*="color:#2563eb"],
    :root[data-theme="dark"] .content [style*="color:#FF7849"],
    :root[data-theme="dark"] .content [style*="color:#f0c030"] { color: inherit; }

    /* ── Bottom Tab Bar (mobile only) ── */
    .bottom-nav {
      display: none;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      background: var(--bg-topbar);
      border-top: 1.5px solid var(--border-color);
      z-index: 9999;
      padding-bottom: env(safe-area-inset-bottom, 0px);
      box-shadow: 0 -4px 20px rgba(0,0,0,0.12);
    }
    @media (max-width: 768px) {
      .bottom-nav { display: flex !important; }
      .content { padding-bottom: 88px !important; }
      body { background: var(--bg-body); }
    }
    .bn-item {
      flex: 1; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      padding: 8px 2px 6px; gap: 3px;
      text-decoration: none; color: var(--text-subtle);
      font-size: 10px; font-weight: 600; letter-spacing: 0.02em;
      transition: color 0.15s; cursor: pointer;
      border: none; background: none; font-family: inherit;
      -webkit-tap-highlight-color: transparent;
      min-width: 0;
    }
    .bn-item.active { color: var(--primary, #1976C2); }
    .bn-item .bn-icon { width: 24px; height: 24px; display: block; flex-shrink: 0; }
    .bn-item.active .bn-icon { transform: scale(1.1); transition: transform 0.15s; }
    .bn-label { font-size: 10px; line-height: 1; white-space: nowrap; }

    /* ── Photo Lightbox ── */
    #photo-lightbox.open { display: flex !important; animation: lb-in 0.18s ease; }
    @keyframes lb-in { from { opacity:0; } to { opacity:1; } }
    #photo-lightbox img { animation: lb-scale 0.2s cubic-bezier(0.34,1.56,0.64,1); }
