<script>
  function openSidebar() {
    document.getElementById('sidebar')!.classList.add('open');
    document.getElementById('sidebar-overlay')!.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    document.getElementById('sidebar')!.classList.remove('open');
    document.getElementById('sidebar-overlay')!.classList.remove('open');
    document.body.style.overflow = '';
  }
  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) closeSidebar();
  });
  let touchStartX = 0;
  document.getElementById('sidebar')!.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; });
  document.getElementById('sidebar')!.addEventListener('touchend', (e) => {
    if (touchStartX - e.changedTouches[0].clientX > 60) closeSidebar();
  });
  (window as any).openSidebar = openSidebar;
  (window as any).closeSidebar = closeSidebar;

  // ── Photo Lightbox ──
  function openLightbox(src: string, name?: string) {
    const lb = document.getElementById('photo-lightbox')!;
    const img = document.getElementById('photo-lightbox-img') as HTMLImageElement;
    const nameEl = document.getElementById('photo-lightbox-name')!;
    img.src = src;
    nameEl.textContent = name || '';
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeLightbox() {
    const lb = document.getElementById('photo-lightbox')!;
    lb.classList.remove('open');
    document.body.style.overflow = '';
    setTimeout(() => { (document.getElementById('photo-lightbox-img') as HTMLImageElement).src = ''; }, 200);
  }
  // Close on Escape key
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });
  // Handle all [data-lightbox] clicks (works for dynamically added elements too)
  document.addEventListener('click', (e) => {
    const el = (e.target as HTMLElement).closest('[data-lightbox]') as HTMLElement | null;
    if (el) openLightbox(el.dataset.lightbox!, el.dataset.lightboxName);
  });
  (window as any).openLightbox = openLightbox;
  (window as any).closeLightbox = closeLightbox;

  // ── Dark mode toggle ──
  // Patches inline styles that hardcode light colors
  function patchInlineDark(isDark: boolean) {
    const LIGHT_BG = ['background:white','background: white','background-color:white','background-color: white',
      'background:#fff','background: #fff','background:#ffffff','background: #ffffff',
      'background:#f9fafb','background:#f8fafc','background:#f3f4f6','background:#f1f5f9','background:#f4f5f7',
      'background:#fafafa','background: #fafafa','background-color:#fff','background-color:#ffffff',
      'background:#fef2f2','background:#eff6ff','background:#f0fdf4','background:#fef9ee','background:#f5f3ff',
      'background:#ecfeff','background:#fef3c7','background:#fafaf9'];
    const DARK_TEXT = ['color:#111827','color: #111827','color:#1f2937','color: #1f2937',
      'color:#374151','color: #374151','color:#0f172a','color: #0f172a',
      'color:#6b7280','color: #6b7280','color:#4b5563','color: #4b5563',
      'color:#000000','color:#000','color:#1C0808','color: #1C0808',
      'color:#1c0808','color: #1c0808','color:#0A2540','color: #0A2540',
      'color:#3f3f46','color: #3f3f46','color:#27272a','color: #27272a'];
    const LIGHT_BORDER = ['border-bottom:1px solid #f0f1f3','border-bottom:1px solid #f9fafb',
      'border-bottom:1px solid #e5e7eb','border:1.5px solid #e5e7eb','border:1px solid #e5e7eb',
      'border-color:#e5e7eb','border-color:#d1d5db','border-color:#f0f1f3'];

    document.querySelectorAll('[style]').forEach(el => {
      const h = el as HTMLElement;
      const s = h.getAttribute('style') || '';
      if (isDark) {
        if (LIGHT_BG.some(p => s.includes(p))) {
          h.style.setProperty('background', 'var(--bg-card)', 'important');
        }
        if (DARK_TEXT.some(p => s.includes(p))) {
          h.style.setProperty('color', 'var(--text-primary)', 'important');
        }
        if (LIGHT_BORDER.some(p => s.includes(p))) {
          h.style.setProperty('border-color', 'var(--border-color)', 'important');
        }
      } else {
        // Restore: remove !important overrides (let inline styles take back over)
        if (h.style.getPropertyPriority('background') === 'important') h.style.removeProperty('background');
        if (h.style.getPropertyPriority('color') === 'important') h.style.removeProperty('color');
        if (h.style.getPropertyPriority('border-color') === 'important') h.style.removeProperty('border-color');
      }
    });
  }

  function applyTheme(theme: string) {
    document.documentElement.setAttribute('data-theme', theme);
    const icon = document.getElementById('theme-icon');
    if (icon) icon.textContent = theme === 'dark' ? '☀️' : '🌙';
    const meta = document.querySelector('meta[name="theme-color"]') as HTMLMetaElement | null;
    if (meta) meta.content = theme === 'dark' ? '#0b1220' : '#1976C2';
    patchInlineDark(theme === 'dark');
  }
  function toggleTheme() {
    const current = document.documentElement.getAttribute('data-theme') || 'light';
    const next = current === 'dark' ? 'light' : 'dark';
    localStorage.setItem('theme', next);
    applyTheme(next);
  }
  (window as any).toggleTheme = toggleTheme;
  // Restore on load (head inline script already applied dark mode to avoid FOUC)
  const saved = localStorage.getItem('theme');
  if (saved === 'dark' || saved === 'light') applyTheme(saved);
</script>
<script>
  // Register service worker
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('/sw.js', { scope: '/' })
        .then(reg => console.log('SW registered:', reg.scope))
        .catch(err => console.log('SW registration failed:', err));
    });
  }

  // PWA install prompt — once per session; permanent only if installed
  // Migrate old pwa-dismissed key (no longer used)
  if (localStorage.getItem('pwa-dismissed') && !localStorage.getItem('pwa-installed')) {
    localStorage.removeItem('pwa-dismissed');
  }
  let deferredPrompt: any;
  window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    deferredPrompt = e;
    const shownThisSession = sessionStorage.getItem('pwa-shown');
    const alreadyInstalled = localStorage.getItem('pwa-installed');
    const isStandalone = window.matchMedia('(display-mode: standalone)').matches;
    if (!shownThisSession && !alreadyInstalled && !isStandalone) {
      sessionStorage.setItem('pwa-shown', '1');
      setTimeout(showInstallBanner, 3000);
    }
  });

  function showInstallBanner() {
    if (document.getElementById('pwa-banner')) return;
    const banner = document.createElement('div');
    banner.id = 'pwa-banner';
    banner.innerHTML = `
      <div style="position:fixed;bottom:70px;left:50%;transform:translateX(-50%);background:#1C0808;border:1px solid #FF7849;border-radius:14px;padding:14px 20px;display:flex;align-items:center;gap:14px;z-index:9999;box-shadow:0 8px 32px rgba(0,0,0,0.4);max-width:340px;width:calc(100% - 40px)">
        <span style="font-size:28px">🏟️</span>
        <div style="flex:1">
          <div style="color:white;font-weight:700;font-size:14px">Instalează SportHub</div>
          <div style="color:#9ca3af;font-size:12px">Acces rapid de pe ecranul principal</div>
        </div>
        <button onclick="installPWA()" style="background:#1976C2;color:white;border:none;border-radius:8px;padding:8px 14px;font-size:13px;font-weight:700;cursor:pointer">Instalează</button>
        <button onclick="dismissPWA()" style="background:none;border:none;color:#6b7280;font-size:18px;cursor:pointer;padding:4px">×</button>
      </div>
    `;
    document.body.appendChild(banner);
  }

  function dismissPWA() {
    // dismissed this session — will re-appear next session
    document.getElementById('pwa-banner')?.remove();
  }

  async function installPWA() {
    if (!deferredPrompt) return;
    deferredPrompt.prompt();
    const { outcome } = await deferredPrompt.userChoice;
    deferredPrompt = null;
    if (outcome === 'accepted') {
      localStorage.setItem('pwa-installed', '1');
    }
    document.getElementById('pwa-banner')?.remove();
  }

  (window as any).installPWA = installPWA;
  (window as any).dismissPWA = dismissPWA;
</script>

<!-- Push notification subscription -->
<script define:vars={{ vapidPublicKey }}>
(function() {
  if (!('serviceWorker' in navigator) || !('PushManager' in window) || !vapidPublicKey) return;

  const bell = document.getElementById('push-bell');
  const dot  = document.getElementById('push-dot');
  if (!bell) return;

  bell.style.display = 'flex';

  function urlB64ToUint8(b64) {
    const pad = '='.repeat((4 - b64.length % 4) % 4);
    const raw = atob((b64 + pad).replace(/-/g, '+').replace(/_/g, '/'));
    return Uint8Array.from(raw, c => c.charCodeAt(0));
  }

  async function getRegistration() {
    const regs = await navigator.serviceWorker.getRegistrations();
    return regs.find(r => r.active) ?? await navigator.serviceWorker.ready;
  }

  async function checkStatus() {
    const perm = Notification.permission;
    if (perm === 'granted') {
      const reg  = await getRegistration();
      const sub  = await reg.pushManager.getSubscription();
      if (sub) {
        dot.style.display = 'block';
        bell.title = 'Notificări push: ACTIVE — click pentru a dezactiva';
        return;
      }
    }
    dot.style.display = 'none';
    bell.title = 'Activează notificările push';
  }

  async function subscribe() {
    const reg = await getRegistration();
    const sub = await reg.pushManager.subscribe({
      userVisibleOnly: true,
      applicationServerKey: urlB64ToUint8(vapidPublicKey),
    });
    const json = sub.toJSON();
    await fetch('/api/admin/push/subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ endpoint: json.endpoint, keys: json.keys }),
    });
    dot.style.display = 'block';
    bell.title = 'Notificări push: ACTIVE — click pentru a dezactiva';
  }

  async function unsubscribe() {
    const reg = await getRegistration();
    const sub = await reg.pushManager.getSubscription();
    if (sub) {
      await fetch('/api/admin/push/subscribe', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ endpoint: sub.endpoint }),
      });
      await sub.unsubscribe();
    }
    dot.style.display = 'none';
    bell.title = 'Activează notificările push';
  }

  bell.addEventListener('click', async () => {
    bell.disabled = true;
    try {
      const reg = await getRegistration();
      const sub = await reg.pushManager.getSubscription();
      if (sub) {
        await unsubscribe();
      } else {
        const perm = await Notification.requestPermission();
        if (perm === 'granted') {
          await subscribe();
        } else {
          alert('Notificările au fost blocate în browser. Activează-le din setările browserului.');
        }
      }
    } catch(e) {
      console.error('Push error:', e);
    } finally {
      bell.disabled = false;
    }
  });

  checkStatus();
})();
</script>

<!-- Cookie Consent Banner -->
<div id="cookie-banner" style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:9999;background:#1C0808;border-top:2px solid #FF7849;padding:14px 24px;box-shadow:0 -4px 20px rgba(0,0,0,0.3)">
  <div style="max-width:900px;margin:0 auto;display:flex;align-items:center;gap:16px;flex-wrap:wrap">
    <p style="color:rgba(255,255,255,0.85);font-size:13px;line-height:1.5;flex:1;margin:0">
      Folosim cookie-uri pentru autentificare și funcționalitatea platformei.
      Prin continuarea utilizării, ești de acord cu
      <a href="/politica-cookie" style="color:#FF7849;text-decoration:underline">Politica Cookie</a> și
      <a href="/gdpr" style="color:#FF7849;text-decoration:underline">Politica GDPR</a>.
    </p>
    <div style="display:flex;gap:8px;flex-shrink:0">
      <button id="cookie-decline" style="background:none;border:1px solid rgba(255,255,255,0.3);color:rgba(255,255,255,0.7);font-size:13px;font-weight:600;padding:7px 16px;border-radius:6px;cursor:pointer">Refuz</button>
      <button id="cookie-accept" style="background:#FF7849;border:none;color:#1C0808;font-size:13px;font-weight:800;padding:7px 18px;border-radius:6px;cursor:pointer">Sunt de acord</button>
    </div>
  </div>
</div>
<script is:inline>
(function() {
  var consent = localStorage.getItem('cookie-consent');
  var banner = document.getElementById('cookie-banner');
  if (!consent && banner) banner.style.display = 'block';
  var btnA = document.getElementById('cookie-accept');
  var btnD = document.getElementById('cookie-decline');
  if (btnA) btnA.addEventListener('click', function() {
    localStorage.setItem('cookie-consent', 'accepted');
    if (banner) banner.style.display = 'none';
  });
  if (btnD) btnD.addEventListener('click', function() {
    localStorage.setItem('cookie-consent', 'declined');
    if (banner) banner.style.display = 'none';
  });
})();
</script>
</body>
</html>
