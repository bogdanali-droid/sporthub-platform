---
/**
 * Reusable tab navigation component for detail pages
 * Used in Player, Team, Match, etc. detail pages
 */

interface Tab {
  id: string;
  label: string;
  icon?: string;
}

interface Props {
  tabs: Tab[];
  currentTab: string;
  basePath: string;
  className?: string;
}

const { tabs, currentTab, basePath, className = '' } = Astro.props;
---

<div class={`tabs-nav ${className}`}>
  {tabs.map((tab) => (
    <a
      href={`${basePath}?tab=${tab.id}`}
      class={`tab-btn ${currentTab === tab.id ? 'active' : ''}`}
      data-tab={tab.id}
    >
      {tab.icon && <span class="tab-icon">{tab.icon}</span>}
      <span>{tab.label}</span>
    </a>
  ))}
</div>

<style>
  .tabs-nav {
    display: flex;
    gap: 8px;
    border-bottom: 2px solid #e2e8f0;
    margin-bottom: 24px;
    padding-bottom: 0;
    flex-wrap: wrap;
  }

  .tab-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 18px;
    border: none;
    background: transparent;
    color: #64748b;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    border-bottom: 3px solid transparent;
    transition: all 0.2s ease;
    position: relative;
    bottom: -2px;
  }

  .tab-btn:hover {
    color: #1e293b;
    background: #f8fafc;
    border-bottom-color: #cbd5e1;
  }

  .tab-btn.active {
    color: #1976c2;
    border-bottom-color: #1976c2;
    background: #f0f9ff;
  }

  .tab-icon {
    font-size: 18px;
    display: inline-flex;
    align-items: center;
  }

  @media (max-width: 768px) {
    .tabs-nav {
      gap: 4px;
    }

    .tab-btn {
      padding: 10px 14px;
      font-size: 13px;
    }

    .tab-icon {
      font-size: 16px;
    }
  }
</style>
