---
const user = Astro.locals.user;
if (user) {
  const { role, sport_code, sport_codes } = user as any;
  if (!sport_code && (sport_codes?.length ?? 0) > 1) return Astro.redirect('/sport-select');
  if (role === 'PARENT') return Astro.redirect('/parent');
  if (role === 'PLAYER') return Astro.redirect('/player');
  if (role === 'FEDERATION_ADMIN') return Astro.redirect('/federatie-admin');
  if (role === 'ASSOCIATION_ADMIN') return Astro.redirect('/asociatie-admin');
  return Astro.redirect('/admin');
}
---

<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SportHub România — Platforma multi-sport</title>
  <link rel="icon" type="image/svg+xml" href="/sporthub-favicon-32.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@600;700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: linear-gradient(160deg, #0A2540 0%, #0D3A5F 100%);
      color: #e2e8f0; min-height: 100vh;
    }
    .header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 20px 40px; border-bottom: 1px solid rgba(255,255,255,.07);
    }
    .header-brand { display: flex; align-items: center; gap: 10px; }
    .header-brand .icon { font-size: 28px; }
    .header-brand .name { font-size: 20px; font-weight: 800; color: #fff; }
    .btn-login {
      background: rgba(255,255,255,.1); color: #e2e8f0;
      border: 1px solid rgba(255,255,255,.2);
      padding: 8px 18px; border-radius: 8px; font-size: 13px; font-weight: 600;
      text-decoration: none; transition: background .15s;
    }
    .btn-login:hover { background: rgba(255,255,255,.18); }

    .hero { text-align: center; padding: 80px 24px 60px; }
    .hero-tag {
      display: inline-block;
      background: rgba(255,120,73,.15); color: #FF7849;
      border: 1px solid rgba(255,120,73,.3);
      padding: 4px 14px; border-radius: 20px; font-size: 12px; font-weight: 700;
      letter-spacing: .05em; text-transform: uppercase; margin-bottom: 20px;
    }
    .hero h1 {
      font-family: 'Space Grotesk', sans-serif;
      font-size: 52px; font-weight: 900; color: #fff; line-height: 1.1; margin-bottom: 20px;
    }
    .hero h1 span { color: #FF7849; }
    .hero p { font-size: 18px; color: #94a3b8; max-width: 560px; margin: 0 auto 36px; line-height: 1.6; }
    .hero-cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    .btn-primary {
      background: #1976C2; color: #fff;
      padding: 14px 28px; border-radius: 10px; font-size: 15px; font-weight: 700;
      text-decoration: none; transition: transform .15s, box-shadow .15s;
      display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(25,118,194,.4); background: #114B7E; }
    .btn-secondary {
      background: rgba(255,255,255,.08); color: #e2e8f0;
      border: 1px solid rgba(255,255,255,.15);
      padding: 14px 28px; border-radius: 10px; font-size: 15px; font-weight: 600;
      text-decoration: none; transition: background .15s;
      display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-secondary:hover { background: rgba(255,255,255,.13); }

    .section { padding: 40px 40px 60px; }
    .section-label {
      text-align: center; font-size: 12px; font-weight: 700; letter-spacing: .1em;
      text-transform: uppercase; color: #475569; margin-bottom: 24px;
    }
    .sports-grid {
      display: flex; justify-content: center; gap: 16px; flex-wrap: wrap;
      max-width: 660px; margin: 0 auto;
    }
    .sport-card {
      background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1);
      border-radius: 16px; padding: 28px 36px; text-align: center;
      transition: all .2s; text-decoration: none;
      flex: 1; min-width: 200px; max-width: 280px;
    }
    .sport-card:hover { background: rgba(255,255,255,.1); transform: translateY(-3px); border-color: rgba(255,255,255,.2); }
    .sport-emoji { font-size: 44px; margin-bottom: 12px; display: block; }
    .sport-name { font-size: 18px; font-weight: 700; color: #fff; margin-bottom: 4px; }
    .sport-desc { font-size: 12px; color: #64748b; }

    .features-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 16px; max-width: 960px; margin: 0 auto;
    }
    .feature-card {
      background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.07);
      border-radius: 12px; padding: 24px;
    }
    .feature-icon { font-size: 28px; margin-bottom: 12px; }
    .feature-title { font-size: 15px; font-weight: 600; color: #e2e8f0; margin-bottom: 6px; }
    .feature-desc { font-size: 13px; color: #64748b; line-height: 1.5; }

    footer {
      border-top: 1px solid rgba(255,255,255,.07);
      padding: 24px 40px; display: flex; align-items: center; justify-content: space-between;
      font-size: 13px; color: #475569;
    }
    footer a { color: #64748b; text-decoration: none; }
    footer a:hover { color: #94a3b8; }

    @media (max-width: 640px) {
      .hero h1 { font-size: 34px; }
      .header { padding: 16px 20px; }
      .section { padding-left: 20px; padding-right: 20px; }
      footer { flex-direction: column; gap: 8px; text-align: center; }
    }
  </style>
</head>
<body>
  <header class="header">
    <div class="header-brand">
      <img src="/sporthub-logo-dark-bg.svg" alt="SportHub" style="height:36px" />
    </div>
    <a href="/login" class="btn-login">Autentificare</a>
  </header>

  <section class="hero">
    <div class="hero-tag">Platforma oficială FRBS</div>
    <h1>Gestionează sportul<br /><span>de la A la Z</span></h1>
    <p>Legitimări, transferuri, competiții, antrenamente și statistici live pentru Baseball5 și Softball în România.</p>
    <div class="hero-cta">
      <a href="/login" class="btn-primary">⚡ Intră în platformă</a>
      <a href="/login" class="btn-secondary">🏛️ Portal Federație</a>
    </div>
  </section>

  <section class="section">
    <p class="section-label">Sporturi disponibile</p>
    <div class="sports-grid">
      <a href="/login" class="sport-card">
        <span class="sport-emoji">⚾</span>
        <div class="sport-name">Baseball5</div>
        <div class="sport-desc">5 jucători · 5 innings · fără pitcher</div>
      </a>
      <a href="/login" class="sport-card">
        <span class="sport-emoji">🥎</span>
        <div class="sport-name">Softball</div>
        <div class="sport-desc">9 jucători · 7 innings · pitch subarm</div>
      </a>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <p class="section-label">Ce oferă platforma</p>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">📊</div>
        <div class="feature-title">Live Scoring</div>
        <div class="feature-desc">Box score inning cu inning, statistici complete în timp real.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🪪</div>
        <div class="feature-title">Legitimări Digitale</div>
        <div class="feature-desc">Cereri FRBS direct din platformă, număr de licență automat.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">⭐</div>
        <div class="feature-title">Evaluări Jucători</div>
        <div class="feature-desc">Tracking atribute tehnice și tactice, progres vizual în timp.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">👨‍👩‍👧</div>
        <div class="feature-title">Portal Părinți</div>
        <div class="feature-desc">Prezență, plăți, calendar meciuri și progresul copilului.</div>
      </div>
    </div>
  </section>

  <footer>
    <span>© 2026 SportHub România · Federația Română de Baseball și Softball</span>
    <div style="display:flex;gap:16px">
      <a href="/login">Login</a>
      <a href="/api/health">Status</a>
    </div>
  </footer>
</body>
</html>
