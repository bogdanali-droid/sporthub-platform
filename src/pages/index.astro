---
import SportHubBanner from '@/components/SportHubBanner.astro';

const user = Astro.locals.user;
if (user) {
  const { role, sport_code, sport_codes } = user as any;
  if (!sport_code && (sport_codes?.length ?? 0) > 1) return Astro.redirect('/sport-select');
  if (role === 'PARENT') return Astro.redirect('/parent');
  if (role === 'PLAYER') return Astro.redirect('/player');
  if (role === 'FEDERATION_ADMIN') return Astro.redirect('/federatie-admin');
  if (role === 'ASSOCIATION_ADMIN') return Astro.redirect('/asociatie-admin');
  return Astro.redirect('/admin');
}
---

<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SportHub România — Platforma multi-sport</title>
  <link rel="icon" type="image/svg+xml" href="/branding/sporthub-favicon.svg" />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #0A2540 0%, #0F3460 50%, #1a237e 100%);
      color: #f3f4f6; min-height: 100vh;
      line-height: 1.5;
    }
    .header {
      display: flex; align-items: center; justify-content: space-between;
      padding: 24px 48px; border-bottom: 1px solid rgba(255,255,255,.08);
      background: rgba(0,0,0,.2);
    }
    .header-brand { display: flex; align-items: center; gap: 16px; }
    .header-brand img { height: 40px; }
    .btn-login {
      background: #1976C2; color: #fff;
      border: none; padding: 11px 24px; border-radius: 8px;
      font-size: 14px; font-weight: 600;
      text-decoration: none; transition: all .2s;
      cursor: pointer;
    }
    .btn-login:hover { background: #114B7E; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(25,118,194,.3); }

    .hero { text-align: center; padding: 96px 48px 72px; }
    .hero-tag {
      display: inline-block;
      background: rgba(255,120,73,.2); color: #FF7849;
      border: 1px solid rgba(255,120,73,.4);
      padding: 6px 16px; border-radius: 24px; font-size: 11px; font-weight: 700;
      letter-spacing: .08em; text-transform: uppercase; margin-bottom: 28px;
    }
    .hero h1 {
      font-family: 'Outfit', sans-serif;
      font-size: 56px; font-weight: 800; color: #fff;
      line-height: 1.15; margin-bottom: 24px; letter-spacing: -1px;
    }
    .hero h1 .gradient-text {
      background: linear-gradient(90deg, #1976C2 0%, #00D9FF 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero h1 span { color: #FF7849; }
    .hero p { font-size: 19px; color: #cbd5e1; max-width: 620px; margin: 0 auto 48px; line-height: 1.7; }
    .hero-cta { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .btn-primary {
      background: #1976C2; color: #fff;
      padding: 14px 32px; border-radius: 8px; font-size: 15px; font-weight: 700;
      text-decoration: none; transition: all .2s;
      display: inline-flex; align-items: center; gap: 8px;
      border: none; cursor: pointer;
    }
    .btn-primary:hover { transform: translateY(-3px); box-shadow: 0 12px 32px rgba(25,118,194,.35); background: #114B7E; }
    .btn-secondary {
      background: rgba(255,255,255,.12); color: #fff;
      border: 2px solid rgba(255,255,255,.2);
      padding: 12px 30px; border-radius: 8px; font-size: 15px; font-weight: 600;
      text-decoration: none; transition: all .2s;
      display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-secondary:hover { background: rgba(255,255,255,.18); border-color: rgba(255,255,255,.3); transform: translateY(-3px); }

    .section { padding: 64px 48px; }
    .section-label {
      text-align: center; font-size: 11px; font-weight: 800; letter-spacing: .12em;
      text-transform: uppercase; color: #9ca3af; margin-bottom: 32px;
    }
    .sports-grid {
      display: flex; justify-content: center; gap: 24px; flex-wrap: wrap;
      max-width: 720px; margin: 0 auto;
    }
    .sport-card {
      background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15);
      border-radius: 16px; padding: 32px 40px; text-align: center;
      transition: all .3s; text-decoration: none;
      flex: 1; min-width: 240px; max-width: 300px;
      cursor: pointer;
    }
    .sport-card:hover { background: rgba(255,255,255,.12); transform: translateY(-4px); border-color: #1976C2; box-shadow: 0 16px 48px rgba(25,118,194,.25); }
    .sport-emoji { font-size: 52px; margin-bottom: 16px; display: block; }
    .sport-name { font-size: 19px; font-weight: 700; color: #fff; margin-bottom: 8px; }
    .sport-desc { font-size: 13px; color: #b0b9c3; }

    .features-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 24px; max-width: 1080px; margin: 0 auto;
    }
    .feature-card {
      background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12);
      border-radius: 14px; padding: 32px 28px;
      transition: all .3s;
    }
    .feature-card:hover { background: rgba(255,255,255,.1); border-color: #1976C2; transform: translateY(-2px); }
    .feature-icon { font-size: 32px; margin-bottom: 16px; }
    .feature-title { font-size: 16px; font-weight: 700; color: #fff; margin-bottom: 8px; }
    .feature-desc { font-size: 13px; color: #b0b9c3; line-height: 1.6; }

    footer {
      border-top: 1px solid rgba(255,255,255,.08);
      padding: 32px 48px; display: flex; align-items: center; justify-content: space-between;
      font-size: 13px; color: #9ca3af;
      background: rgba(0,0,0,.2);
    }
    footer a { color: #cbd5e1; text-decoration: none; transition: color .2s; }
    footer a:hover { color: #1976C2; }

    @media (max-width: 768px) {
      .header { padding: 16px 24px; }
      .hero { padding: 60px 24px 48px; }
      .hero h1 { font-size: 40px; }
      .hero p { font-size: 16px; }
      .hero-cta { gap: 12px; }
      .btn-primary, .btn-secondary { padding: 12px 24px; font-size: 14px; }
      .section { padding: 48px 24px; }
      .sports-grid { gap: 16px; }
      .sport-card { padding: 24px 28px; min-width: 200px; }
      .features-grid { gap: 16px; }
      .feature-card { padding: 24px 20px; }
      footer { flex-direction: column; gap: 12px; text-align: center; padding: 24px; }
    }
  </style>
</head>
<body>
  <header class="header">
    <div class="header-brand">
      <img src="/branding/sporthub-logo-white.svg" alt="SportHub" style="height:36px" />
    </div>
    <a href="/login" class="btn-login">Autentificare</a>
  </header>

  <section class="hero">
    <div class="hero-tag">Platforma oficială FRBS</div>
    <h1>Gestionează sportul<br /><span class="gradient-text">de la A la Z</span></h1>
    <p>Legitimări, transferuri, competiții, antrenamente și statistici live pentru Baseball5 și Softball în România.</p>
    <div class="hero-cta">
      <a href="/login" class="btn-primary">⚡ Intră în platformă</a>
      <a href="/login" class="btn-secondary">🏛️ Portal Federație</a>
    </div>

    <div style="max-width:1200px;margin:64px auto 0;padding:0 24px">
      <SportHubBanner href="/login" speed={5} />
    </div>
  </section>

  <section class="section">
    <p class="section-label">Sporturi disponibile</p>
    <div class="sports-grid">
      <a href="/login" class="sport-card">
        <span class="sport-emoji">⚾</span>
        <div class="sport-name">Baseball5</div>
        <div class="sport-desc">5 jucători · 5 innings · fără pitcher</div>
      </a>
      <a href="/login" class="sport-card">
        <span class="sport-emoji">🥎</span>
        <div class="sport-name">Softball</div>
        <div class="sport-desc">9 jucători · 7 innings · pitch subarm</div>
      </a>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <p class="section-label">Ce oferă platforma</p>
    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">📊</div>
        <div class="feature-title">Live Scoring</div>
        <div class="feature-desc">Box score inning cu inning, statistici complete în timp real.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🪪</div>
        <div class="feature-title">Legitimări Digitale</div>
        <div class="feature-desc">Cereri FRBS direct din platformă, număr de licență automat.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">⭐</div>
        <div class="feature-title">Evaluări Jucători</div>
        <div class="feature-desc">Tracking atribute tehnice și tactice, progres vizual în timp.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">👨‍👩‍👧</div>
        <div class="feature-title">Portal Părinți</div>
        <div class="feature-desc">Prezență, plăți, calendar meciuri și progresul copilului.</div>
      </div>
    </div>
  </section>

  <footer>
    <span>© 2026 SportHub România · Federația Română de Baseball și Softball</span>
    <div style="display:flex;gap:16px">
      <a href="/login">Login</a>
      <a href="/api/health">Status</a>
    </div>
  </footer>
</body>
</html>
