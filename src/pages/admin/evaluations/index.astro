---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { queryAll } from '@/lib/db';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const db = (Astro.locals as any).runtime?.env?.DB;
const clubId = (Astro.locals as any).clubId ?? user.club_id;

const evaluations = await queryAll<any>(db, `
  SELECT pes.*, p.first_name, p.last_name, p.jersey_number,
         t.name as team_name, sea.name_ro as attribute_name
  FROM player_evaluation_scores pes
  JOIN players p ON pes.player_id = p.id
  LEFT JOIN team_players tp ON p.id = tp.player_id AND tp.left_at IS NULL
  LEFT JOIN teams t ON tp.team_id = t.id
  LEFT JOIN sport_evaluation_attributes sea ON pes.eval_attr = sea.code
  WHERE p.club_id = ?
  ORDER BY p.last_name, p.first_name, pes.created_at DESC
`, [clubId]);

// Group by player
const grouped: any = {};
evaluations.forEach((e: any) => {
  const key = e.player_id;
  if (!grouped[key]) {
    grouped[key] = {
      player_id: e.player_id,
      first_name: e.first_name,
      last_name: e.last_name,
      jersey_number: e.jersey_number,
      team_name: e.team_name,
      scores: []
    };
  }
  grouped[key].scores.push(e);
});

const players = Object.values(grouped);
---

<AdminLayout title="Evaluări jucători">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:24px">
    <h2 style="font-size:18px;font-weight:700;color:#1e293b">Evaluări jucători</h2>
  </div>

  {players.length === 0 ? (
    <div class="card" style="text-align:center;padding:40px;color:#94a3b8">
      <div style="font-size:48px;margin-bottom:16px">📊</div>
      <p>Nicio evaluare încă. Adaugă evaluări jucătorilor din pagina meciurilor.</p>
    </div>
  ) : (
    <div style="display:grid;gap:12px">
      {players.map((p: any) => (
        <a href={`/admin/evaluations/${p.player_id}`} style="text-decoration:none">
          <div class="card" style="cursor:pointer;transition:all 0.2s;padding:16px;margin-bottom:0">
            <div style="display:flex;justify-content:space-between;align-items:center">
              <div>
                <div style="font-weight:600;color:#1e293b;font-size:15px">
                  #{p.jersey_number || '?'} {p.first_name} {p.last_name}
                </div>
                <div style="font-size:13px;color:#6b7280;margin-top:2px">
                  {p.team_name || 'Fără echipă'} · {p.scores.length} evaluar{p.scores.length !== 1 ? 'i' : 'e'}
                </div>
              </div>
              <div style="color:#9ca3af">→</div>
            </div>
          </div>
        </a>
      ))}
    </div>
  )}
</AdminLayout>
