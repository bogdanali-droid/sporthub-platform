---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
const { id } = Astro.params;
const doc = await (Astro.locals as any).runtime?.env?.DB?.prepare('SELECT d.*, p.first_name, p.last_name FROM documents d JOIN players p ON d.player_id = p.id WHERE d.id = ? AND p.club_id = ?').bind(id, (Astro.locals as any).clubId).first();
if (!doc) return Astro.redirect('/admin/documents');
---
<AdminLayout title={`Document - ${doc.first_name} ${doc.last_name}`}>
  <a href="/admin/documents" style="color:#6b7280;font-size:14px;text-decoration:none;display:inline-flex;align-items:center;gap:6px;margin-bottom:20px">← Înapoi</a>
  <div class="card">
    <h2 style="font-size:16px;font-weight:700;margin-bottom:24px;color:#1e293b">{doc.first_name} {doc.last_name}</h2>
    <div style="display:grid;gap:16px">
      <div><label style="font-weight:700;color:#6b7280;font-size:12px;text-transform:uppercase">Tip document</label><p style="margin-top:4px">{doc.document_type}</p></div>
      <div><label style="font-weight:700;color:#6b7280;font-size:12px;text-transform:uppercase">Nume fișier</label><p style="margin-top:4px">{doc.filename}</p></div>
      <div><label style="font-weight:700;color:#6b7280;font-size:12px;text-transform:uppercase">Dată încărcării</label><p style="margin-top:4px">{doc.uploaded_at}</p></div>
      {doc.file_url && <div><a href={doc.file_url} target="_blank" class="btn btn-primary" style="padding:8px 16px;font-size:13px">📥 Descarcă</a></div>}
    </div>
  </div>
</AdminLayout>
