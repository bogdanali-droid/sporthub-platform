---
import AdminLayout from '@/layouts/AdminLayout.astro';
if (!Astro.locals.user) return Astro.redirect('/login');

const user = Astro.locals.user;
const env = (Astro.locals as any).runtime?.env;
const db = env?.DB;
const { id } = Astro.params;

import { queryFirst, queryAll } from '@/lib/db';
import { getClubSportConfig } from '@/lib/sport-config';

const sport = await getClubSportConfig(db, user.club_id!);
const cerere = await queryFirst<any>(db,
  `SELECT fr.*, p.first_name || ' ' || p.last_name AS player_name
   FROM federation_requests fr LEFT JOIN players p ON p.id = fr.player_id
   WHERE fr.id = ? AND fr.club_id = ?`, [id, user.club_id]);

if (!cerere) return Astro.redirect('/admin/federatie');

const mesaje = await queryAll<any>(db,
  `SELECT * FROM federation_request_messages WHERE request_id = ? ORDER BY created_at ASC`, [id]);

const msg = Astro.url.searchParams.get('msg');

const statusBadge: Record<string, string> = {
  PENDING: 'badge-yellow', IN_REVIEW: 'badge-blue', APPROVED: 'badge-green',
  REJECTED: 'badge-red', INFO_NEEDED: 'badge-gold',
};
const statusLabel: Record<string, string> = {
  PENDING: 'În așteptare', IN_REVIEW: 'În analiză', APPROVED: 'Aprobat',
  REJECTED: 'Respins', INFO_NEEDED: 'Info necesară',
};
---

<AdminLayout title="Cerere federație" user={user} sportCode={sport?.code} sportIcon={sport?.icon}>

  <div style="margin-bottom:16px">
    <a href="/admin/federatie" style="color:#64748b;font-size:13px;text-decoration:none">← Înapoi la Portal Federație</a>
  </div>

  {msg === 'trimis' && <div class="alert alert-success">Mesaj trimis cu succes.</div>}

  <div style="display:grid;grid-template-columns:1fr 280px;gap:20px">

    <!-- Thread mesaje -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">{cerere.subject}</span>
        <span class={`badge ${statusBadge[cerere.status] ?? 'badge-gray'}`}>{statusLabel[cerere.status] ?? cerere.status}</span>
      </div>

      {cerere.description && (
        <div style="background:#f8fafc;border-radius:8px;padding:12px 16px;margin-bottom:16px;font-size:13.5px;color:#374151">
          {cerere.description}
        </div>
      )}

      <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:20px">
        {mesaje.length === 0 && <p style="color:#94a3b8;font-size:13px;text-align:center;padding:16px 0">Niciun mesaj încă.</p>}
        {mesaje.map((m: any) => (
          <div style={`display:flex;flex-direction:column;align-items:${m.sender_role === 'CLUB' ? 'flex-end' : 'flex-start'}`}>
            <div style={`max-width:80%;padding:10px 14px;border-radius:10px;font-size:13.5px;${m.sender_role === 'CLUB' ? 'background:#0a1929;color:#fff;border-bottom-right-radius:2px' : 'background:#f1f5f9;color:#1e293b;border-bottom-left-radius:2px'}`}>
              {m.message}
            </div>
            <span style="font-size:11px;color:#94a3b8;margin-top:3px">{m.sender_role === 'CLUB' ? 'Tu' : 'FRBS'} · {m.created_at?.slice(0,16)}</span>
          </div>
        ))}
      </div>

      {!['APPROVED','REJECTED'].includes(cerere.status) && (
        <form method="POST" action={`/api/admin/federatie/cereri/${id}/message`}>
          <textarea name="message" class="form-textarea" rows="3" placeholder="Scrie un mesaj..." required></textarea>
          <div style="display:flex;justify-content:flex-end;margin-top:8px">
            <button type="submit" class="btn btn-primary">Trimite mesaj</button>
          </div>
        </form>
      )}
    </div>

    <!-- Detalii cerere -->
    <div>
      <div class="card">
        <div class="card-title" style="margin-bottom:12px">Detalii</div>
        <dl style="font-size:13px;display:flex;flex-direction:column;gap:8px">
          <div><dt style="color:#64748b">Tip</dt><dd style="font-weight:500">{cerere.request_type}</dd></div>
          <div><dt style="color:#64748b">Jucător</dt><dd>{cerere.player_name ?? '—'}</dd></div>
          <div><dt style="color:#64748b">Sport</dt><dd>{cerere.sport_code ?? '—'}</dd></div>
          <div><dt style="color:#64748b">Prioritate</dt><dd>{cerere.priority}</dd></div>
          <div><dt style="color:#64748b">Data</dt><dd>{cerere.created_at?.slice(0,10)}</dd></div>
          {cerere.resolved_at && <div><dt style="color:#64748b">Rezolvat</dt><dd>{cerere.resolved_at?.slice(0,10)}</dd></div>}
        </dl>
        {cerere.response_notes && (
          <div style="margin-top:12px;padding:10px;background:#f0fdf4;border-radius:6px;font-size:13px;color:#166534">
            <strong>Răspuns FRBS:</strong> {cerere.response_notes}
          </div>
        )}
      </div>
    </div>

  </div>

</AdminLayout>

<style>
  .card { background:#fff;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,.06);padding:20px 24px; }
  .card-header { display:flex;align-items:center;justify-content:space-between;margin-bottom:16px; }
  .card-title { font-size:15px;font-weight:600;color:#1e293b; }
  .btn { display:inline-flex;align-items:center;gap:6px;padding:8px 16px;border-radius:7px;font-size:13.5px;font-weight:500;cursor:pointer;border:none;text-decoration:none; }
  .btn-primary { background:#0a1929;color:#fff; }
  .badge { display:inline-flex;padding:3px 9px;border-radius:12px;font-size:11px;font-weight:600; }
  .badge-green { background:#dcfce7;color:#166534; }
  .badge-yellow { background:#fef9c3;color:#854d0e; }
  .badge-red { background:#fee2e2;color:#991b1b; }
  .badge-blue { background:#dbeafe;color:#1d4ed8; }
  .badge-gray { background:#f1f5f9;color:#475569; }
  .badge-gold { background:#fef3c7;color:#92400e; }
  .alert { padding:12px 16px;border-radius:8px;font-size:13.5px;margin-bottom:16px; }
  .alert-success { background:#f0fdf4;border:1px solid #bbf7d0;color:#166534; }
  .form-textarea { width:100%;padding:9px 12px;border:1.5px solid #e2e8f0;border-radius:7px;font-size:14px;outline:none; }
</style>
