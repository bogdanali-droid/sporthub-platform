---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const db = (Astro.locals as any).runtime?.env?.DB;
const clubId = user.club_id;

const trainings = db ? (await db.prepare(`
  SELECT t.id, t.title, t.start_time, t.status, tm.name as team_name,
    (SELECT COUNT(*) FROM attendance a WHERE a.training_id = t.id AND a.status='PRESENT') as present,
    (SELECT COUNT(*) FROM attendance a WHERE a.training_id = t.id) as total
  FROM trainings t LEFT JOIN teams tm ON tm.id = t.team_id
  WHERE t.club_id = ? ORDER BY t.start_time DESC LIMIT 50
`).bind(clubId).all())?.results ?? [] : [];
---
<AdminLayout title="Prezență">
  <div style="margin-bottom:20px;display:flex;align-items:center;justify-content:space-between">
    <div>
      <h2 style="font-size:20px;font-weight:800">Prezență</h2>
      <p style="color:#6b7280;font-size:13px">Statistici prezență per antrenament</p>
    </div>
  </div>

  <div class="card" style="padding:0;overflow:hidden">
    {(trainings as any[]).length === 0 ? (
      <div style="padding:60px 24px;text-align:center;color:#9ca3af">
        <div style="font-size:40px;margin-bottom:12px">✅</div>
        <p style="font-weight:600">Niciun antrenament înregistrat</p>
        <p style="font-size:13px;margin-top:4px">Adaugă antrenamente din secțiunea Antrenamente</p>
      </div>
    ) : (
      <table class="table">
        <thead><tr><th>Antrenament</th><th>Echipă</th><th>Data</th><th>Prezență</th><th>Acțiuni</th></tr></thead>
        <tbody>
          {(trainings as any[]).map((t: any) => (
            <tr>
              <td style="font-weight:600">{t.title}</td>
              <td style="color:#6b7280">{t.team_name || '—'}</td>
              <td style="color:#6b7280;font-size:13px">{t.start_time?.slice(0,16).replace('T',' ')}</td>
              <td>
                <span style={`font-weight:700;color:${t.total > 0 ? '#16a34a' : '#9ca3af'}`}>
                  {t.present}/{t.total}
                </span>
                {t.total > 0 && <span style="color:#9ca3af;font-size:12px;margin-left:6px">({Math.round(t.present/t.total*100)}%)</span>}
              </td>
              <td><a href={`/admin/trainings/${t.id}`} class="btn btn-ghost btn-sm">Detalii</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
