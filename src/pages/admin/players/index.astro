---
import AdminLayout from '@/layouts/AdminLayout.astro';
if (!Astro.locals.user) return Astro.redirect('/login');
const user = Astro.locals.user;
const env = (Astro.locals as any).runtime?.env;
const db = env.DB;
import { queryAll, queryFirst } from '@/lib/db';
import { getClubSportConfig } from '@/lib/sport-config';

const search = Astro.url.searchParams.get('search') || '';
const teamFilter = Astro.url.searchParams.get('team_id') || '';
const statusFilter = Astro.url.searchParams.get('status') || '';
const msg = Astro.url.searchParams.get('msg');

let query = `
  SELECT p.*, tp.team_id, t.name as team_name,
    mv.valid_until as medical_valid_until
  FROM players p
  LEFT JOIN team_players tp ON tp.player_id = p.id AND tp.left_at IS NULL
  LEFT JOIN teams t ON t.id = tp.team_id
  LEFT JOIN (
    SELECT player_id, MAX(visit_date) as latest_date, valid_until
    FROM medical_visits GROUP BY player_id
  ) mv ON mv.player_id = p.id
  WHERE p.club_id = ?
`;
const binds: any[] = [user.club_id];

if (statusFilter) {
  query += ' AND p.status = ?';
  binds.push(statusFilter);
}
if (teamFilter) {
  query += ' AND tp.team_id = ?';
  binds.push(teamFilter);
}
if (search) {
  query += " AND (p.first_name || ' ' || p.last_name LIKE ?)";
  binds.push(`%${search}%`);
}
query += ' ORDER BY p.last_name, p.first_name';

const players = await queryAll<any>(db, query, binds);
const [sport, teams] = await Promise.all([
  getClubSportConfig(db, user.club_id!),
  queryAll<any>(db,
    `SELECT id, name FROM teams WHERE club_id = ? AND is_active = 1 ORDER BY name`,
    [user.club_id]),
]);

const azi = new Date().toISOString().split('T')[0];
const peste30 = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];

function medicalStatus(valid_until: string | null): string {
  if (!valid_until) return 'lipsa';
  if (valid_until < azi) return 'expirata';
  if (valid_until <= peste30) return 'expira_curand';
  return 'ok';
}

function calcAge(birth_date: string | null): string {
  if (!birth_date) return '—';
  const born = new Date(birth_date + 'T00:00:00');
  const now = new Date();
  let age = now.getFullYear() - born.getFullYear();
  const m = now.getMonth() - born.getMonth();
  if (m < 0 || (m === 0 && now.getDate() < born.getDate())) age--;
  return String(age);
}

const statusLabels: Record<string, string> = {
  ACTIVE: 'Activ',
  INACTIVE: 'Inactiv',
  INJURED: 'Accidentat',
  SUSPENDED: 'Suspendat',
  TRANSFERRED: 'Transferat',
};
---

<AdminLayout title={`Jucători (${players.length})`} user={user} sportCode={sport?.code} sportIcon={sport?.icon}>
  {msg === 'salvat' && <div class="alert alert-success">Jucătorul a fost salvat.</div>}
  {msg === 'sters' && <div class="alert alert-success">Jucătorul a fost șters.</div>}

  <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:center;justify-content:space-between;margin-bottom:24px">
    <form method="GET" style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
      <input name="search" class="form-input" style="width:220px" placeholder="Caută jucător..." value={search} />
      <select name="team_id" class="form-select" style="width:180px">
        <option value="">Toate echipele</option>
        {teams.map((t: any) => (
          <option value={t.id} selected={teamFilter === String(t.id)}>{t.name}</option>
        ))}
      </select>
      <select name="status" class="form-select" style="width:160px">
        <option value="">Toate statusurile</option>
        {Object.entries(statusLabels).map(([val, lbl]) => (
          <option value={val} selected={statusFilter === val}>{lbl}</option>
        ))}
      </select>
      <button type="submit" class="btn btn-ghost">Filtrează</button>
      {(search || teamFilter || statusFilter) && <a href="/admin/players" class="btn btn-ghost">✕ Reset</a>}
    </form>
    <div style="display:flex;gap:8px">
      <button onclick="document.getElementById('modal-import').style.display='flex'" class="btn btn-ghost" style="font-size:13px">⬆ Import CSV</button>
      <button class="btn btn-primary" onclick="openModal()">+ Jucător nou</button>
    </div>
  </div>

  <!-- Import CSV Modal -->
  <div id="modal-import" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;padding:20px">
    <div class="card" style="width:100%;max-width:520px;padding:28px">
      <h3 style="font-size:16px;font-weight:700;margin-bottom:8px">Import jucători din CSV</h3>
      <p style="font-size:13px;color:#6b7280;margin-bottom:16px">
        Fișierul CSV trebuie să aibă antet cu coloanele:<br/>
        <code style="background:#f3f4f6;padding:2px 6px;border-radius:4px;font-size:12px">first_name, last_name, birth_date (YYYY-MM-DD), gender (M/F), position, jersey_number, parent_email, status</code>
      </p>
      <div class="form-group">
        <label class="form-label">Fișier CSV *</label>
        <input type="file" id="import-file" accept=".csv,.txt" class="form-input" style="padding:6px" />
      </div>
      <div id="import-result" style="display:none;margin-top:12px;padding:12px;border-radius:8px;font-size:13px"></div>
      <div style="display:flex;gap:10px;margin-top:16px">
        <button type="button" onclick="runImport()" class="btn btn-primary" id="import-btn" style="flex:1">Importă</button>
        <button type="button" onclick="document.getElementById('modal-import').style.display='none'" class="btn btn-ghost">Anulează</button>
      </div>
    </div>
  </div>

  <div class="card" style="padding:0;overflow:hidden">
    <div style="padding:14px 24px;background:#fafafa;border-bottom:1px solid #f3f4f6;font-size:13px;color:#6b7280">
      {players.length} jucători găsiți
    </div>
    <table class="table">
      <thead>
        <tr>
          <th>Jucător</th>
          <th>Echipă</th>
          <th>Vârstă</th>
          <th>Post</th>
          <th>Status</th>
          <th>Viză medicală</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {players.length === 0 ? (
          <tr><td colspan="7" style="text-align:center;color:#9ca3af;padding:40px">Niciun jucător găsit.</td></tr>
        ) : players.map((p: any) => {
          const ms = medicalStatus(p.medical_valid_until);
          return (
            <tr>
              <td>
                <div style="display:flex;align-items:center;gap:10px">
                  {p.photo_url
                    ? <img src={p.photo_url} style="width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid #f3f4f6;cursor:pointer" alt="" data-lightbox={p.photo_url} data-lightbox-name={`${p.first_name} ${p.last_name}`} />
                    : <div style="width:36px;height:36px;border-radius:50%;background:#1976C2;display:flex;align-items:center;justify-content:center;color:white;font-weight:900;font-size:13px;flex-shrink:0">{p.first_name?.[0]}{p.last_name?.[0]}</div>
                  }
                  <div>
                    <div style="font-weight:700;color:#1e293b">{p.first_name} {p.last_name}</div>
                    {p.jersey_number && <div style="font-size:12px;color:#9ca3af">#{p.jersey_number}</div>}
                  </div>
                </div>
              </td>
              <td>
                {p.team_name
                  ? <span class="badge" style="background:#dbeafe;color:#1e40af">{p.team_name}</span>
                  : <span style="color:#9ca3af">—</span>
                }
              </td>
              <td style="color:#6b7280;font-size:13px">{calcAge(p.birth_date)} ani</td>
              <td style="color:#6b7280;font-size:13px">{p.position || '—'}</td>
              <td>
                {p.status === 'ACTIVE' && <span class="badge" style="background:#dcfce7;color:#166534">Activ</span>}
                {p.status === 'INACTIVE' && <span class="badge" style="background:#f3f4f6;color:#6b7280">Inactiv</span>}
                {p.status === 'INJURED' && <span class="badge" style="background:#fef9c3;color:#854d0e">Accidentat</span>}
                {p.status === 'SUSPENDED' && <span class="badge" style="background:#fee2e2;color:#991b1b">Suspendat</span>}
                {p.status === 'TRANSFERRED' && <span class="badge" style="background:#ede9fe;color:#5b21b6">Transferat</span>}
                {!p.status && <span style="color:#9ca3af;font-size:13px">—</span>}
              </td>
              <td>
                {ms === 'ok' && <span class="badge" style="background:#dcfce7;color:#166534">✓ {new Date(p.medical_valid_until + 'T00:00:00').toLocaleDateString('ro-RO')}</span>}
                {ms === 'expira_curand' && <span class="badge" style="background:#fef9c3;color:#854d0e">⚠ {new Date(p.medical_valid_until + 'T00:00:00').toLocaleDateString('ro-RO')}</span>}
                {ms === 'expirata' && <span class="badge" style="background:#fee2e2;color:#991b1b">✕ Expirată</span>}
                {ms === 'lipsa' && <span class="badge" style="background:#fee2e2;color:#991b1b">Lipsă</span>}
              </td>
              <td style="text-align:right">
                <a href={`/admin/players/${p.id}`} class="btn btn-ghost" style="padding:6px 14px;font-size:13px">Profil</a>
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  <!-- MODAL -->
  <div id="modal" class="modal-overlay hidden">
    <div class="modal">
      <div class="modal-head">
        <h2 id="modal-title">Jucător nou</h2>
        <button onclick="closeModal()" class="btn-close">×</button>
      </div>
      <form id="player-form" class="modal-body">
        <input type="hidden" id="player-id" />
        <div class="form-row">
          <div class="form-group">
            <label>Prenume *</label>
            <input id="f-first-name" required />
          </div>
          <div class="form-group">
            <label>Nume *</label>
            <input id="f-last-name" required />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Data naşterii *</label>
            <input id="f-birth-date" type="date" required />
          </div>
          <div class="form-group">
            <label>Gen</label>
            <select id="f-gender">
              <option value="">Selectează</option>
              <option value="M">Masculin</option>
              <option value="F">Feminin</option>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Poziție</label>
            <select id="f-position">
              <option value="">Selectează</option>
              {sport?.positions.map(pos => (
                <option value={pos.code}>{pos.name_ro}{pos.abbreviation ? ` (${pos.abbreviation})` : ''}</option>
              ))}
            </select>
          </div>
          <div class="form-group">
            <label>Nr. tricou</label>
            <input id="f-jersey" type="number" min="1" max="99" />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Echipă</label>
            <select id="f-team">
              <option value="">Fără echipă</option>
              {teams.map(t => (
                <option value={t.id}>{t.name}</option>
              ))}
            </select>
          </div>
          <div class="form-group">
            <label>Status</label>
            <select id="f-status">
              <option value="ACTIVE">Activ</option>
              <option value="INACTIVE">Inactiv</option>
              <option value="INJURED">Accidentat</option>
              <option value="SUSPENDED">Suspendat</option>
              <option value="TRANSFERRED">Transferat</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>Email părinte</label>
          <input id="f-parent-email" type="email" />
        </div>
        <div class="form-group">
          <label>Telefon părinte</label>
          <input id="f-parent-phone" type="tel" />
        </div>
        <div class="modal-footer">
          <button type="button" onclick="closeModal()" class="btn-secondary">Anulează</button>
          <button type="submit" class="btn-primary">Salvează</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<style>
  .card { background: #fff; border: 1px solid #e5e7eb; border-radius: 14px; padding: 20px; box-shadow: 0 1px 4px rgba(0,0,0,.04); }
  .table { width: 100%; border-collapse: collapse; }
  .table th {
    text-align: left; padding: 14px 20px;
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.05em; color: #9ca3af;
    border-bottom: 2px solid #e5e7eb; background: #f9fafb;
  }
  .table td {
    padding: 18px 20px; font-size: 14.5px;
    border-bottom: 1px solid #f0f1f3;
    vertical-align: middle; color: #1e293b;
  }
  .table tr:last-child td { border-bottom: none; }
  .table tr:hover td { background: #f8fafc; }
  .badge { display: inline-flex; align-items: center; padding: 5px 13px; border-radius: 999px; font-size: 12px; font-weight: 700; }
  .form-input, .form-select { width: 100%; padding: 12px 16px; border: 1.5px solid #d1d5db; border-radius: 9px; font-size: 14.5px; outline: none; transition: all 0.15s; background: #fff; color: #1e293b; font-family: inherit; box-shadow: inset 0 1px 2px rgba(0,0,0,.04); }
  .form-input:focus, .form-select:focus { border-color: #1976C2; box-shadow: 0 0 0 3px rgba(25,118,194,.12); }
  .form-label { display: block; font-size: 13px; font-weight: 700; color: #1e293b; margin-bottom: 8px; letter-spacing: 0.01em; }
  .form-group { margin-bottom: 24px; }
  .btn { display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: 9px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; line-height: 1; transition: all 0.15s; white-space: nowrap; border: 1.5px solid transparent; }
  .btn-primary { background: #1976C2; color: white; border-color: #1976C2; box-shadow: 0 2px 6px rgba(25,118,194,.35); }
  .btn-primary:hover { filter: brightness(0.88); box-shadow: 0 3px 10px rgba(25,118,194,.45); }
  .btn-ghost { background: #fff; color: #6b7280; border-color: #d1d5db; box-shadow: 0 1px 3px rgba(0,0,0,.08); }
  .btn-ghost:hover { background: #f8fafc; border-color: #9ca3af; color: #1e293b; }
  .alert { padding: 16px 20px; border-radius: 10px; font-size: 14px; font-weight: 500; margin-bottom: 24px; }
  .alert-success { background: #f0fdf4; color: #166534; border: 1.5px solid #bbf7d0; }
</style>

<script>
  // Search filter
  document.getElementById('search')?.addEventListener('input', e => {
    const q = (e.target as HTMLInputElement).value.toLowerCase();
    document.querySelectorAll<HTMLTableRowElement>('#players-table tbody tr').forEach(row => {
      row.style.display = row.dataset.search?.toLowerCase().includes(q) ? '' : 'none';
    });
  });

  let editingId: string | null = null;

  window.openModal = function() {
    editingId = null;
    (document.getElementById('modal-title') as HTMLElement).textContent = 'Jucător nou';
    (document.getElementById('player-form') as HTMLFormElement).reset();
    (document.getElementById('modal') as HTMLElement).classList.remove('hidden');
  };

  window.closeModal = function() {
    (document.getElementById('modal') as HTMLElement).classList.add('hidden');
    editingId = null;
  };

  window.editPlayer = async function(id: string) {
    const res = await fetch(`/api/admin/players/${id}`);
    if (!res.ok) return;
    const p = await res.json();
    editingId = id;
    (document.getElementById('modal-title') as HTMLElement).textContent = 'Editează jucător';
    (document.getElementById('f-first-name') as HTMLInputElement).value = p.first_name ?? '';
    (document.getElementById('f-last-name') as HTMLInputElement).value = p.last_name ?? '';
    (document.getElementById('f-birth-date') as HTMLInputElement).value = p.birth_date ?? '';
    (document.getElementById('f-gender') as HTMLSelectElement).value = p.gender ?? '';
    (document.getElementById('f-position') as HTMLSelectElement).value = p.position ?? '';
    (document.getElementById('f-jersey') as HTMLInputElement).value = p.jersey_number ?? '';
    (document.getElementById('f-status') as HTMLSelectElement).value = p.status ?? 'ACTIVE';
    (document.getElementById('f-parent-email') as HTMLInputElement).value = p.parent_email ?? '';
    (document.getElementById('f-parent-phone') as HTMLInputElement).value = p.parent_phone ?? '';
    (document.getElementById('modal') as HTMLElement).classList.remove('hidden');
  }

  window.deletePlayer = async function(id: string, name: string) {
    if (!confirm(`Ștergi jucătorul ${name}?`)) return;
    const res = await fetch(`/api/admin/players/${id}`, { method: 'DELETE' });
    if (res.ok) location.reload();
    else alert('Eroare la ștergere.');
  };

  document.getElementById('player-form')?.addEventListener('submit', async e => {
    e.preventDefault();
    const body = {
      first_name:   (document.getElementById('f-first-name') as HTMLInputElement).value,
      last_name:    (document.getElementById('f-last-name') as HTMLInputElement).value,
      birth_date:   (document.getElementById('f-birth-date') as HTMLInputElement).value,
      gender:       (document.getElementById('f-gender') as HTMLSelectElement).value,
      position:     (document.getElementById('f-position') as HTMLSelectElement).value,
      jersey_number:(document.getElementById('f-jersey') as HTMLInputElement).value,
      status:       (document.getElementById('f-status') as HTMLSelectElement).value,
      team_id:      (document.getElementById('f-team') as HTMLSelectElement).value,
      parent_email: (document.getElementById('f-parent-email') as HTMLInputElement).value,
      parent_phone: (document.getElementById('f-parent-phone') as HTMLInputElement).value,
    };
    const url = editingId ? `/api/admin/players/${editingId}` : '/api/admin/players';
    const method = editingId ? 'PUT' : 'POST';
    const res = await fetch(url, { method, headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
    if (res.ok) { closeModal(); location.reload(); }
    else { const err = await res.json(); alert(err.error ?? 'Eroare la salvare.'); }
  });

  // CSV Import
  document.getElementById('modal-import').addEventListener('click', function(e) {
    if (e.target === this) this.style.display = 'none';
  });

  async function runImport() {
    var fileInput = document.getElementById('import-file');
    var file = fileInput && fileInput.files && fileInput.files[0];
    if (!file) { alert('Selectează un fișier CSV.'); return; }
    var btn = document.getElementById('import-btn');
    if (btn) { btn.disabled = true; btn.textContent = 'Se importă...'; }
    var fd = new FormData();
    fd.append('file', file);
    try {
      var res = await fetch('/api/admin/players/import', { method: 'POST', body: fd });
      var data = await res.json();
      var el = document.getElementById('import-result');
      el.style.display = 'block';
      if (data.imported > 0) {
        el.style.background = '#f0fdf4';
        el.style.color = '#166534';
        el.style.border = '1px solid #bbf7d0';
        var msg = '✓ ' + data.imported + ' jucători importați cu succes.';
        if (data.errors && data.errors.length > 0) msg += ' (' + data.errors.length + ' rânduri cu erori)';
        el.textContent = msg;
        setTimeout(function() { window.location.reload(); }, 1500);
      } else {
        el.style.background = '#fef2f2';
        el.style.color = '#991b1b';
        el.style.border = '1px solid #fecaca';
        el.textContent = 'Eroare la import.';
      }
    } catch(e) {
      alert('Eroare de rețea: ' + e);
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'Importă'; }
    }
  }
</script>
