---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
const { id } = Astro.params;
const payment = await (Astro.locals as any).runtime?.env?.DB?.prepare('SELECT p.*, pl.first_name, pl.last_name FROM payments p JOIN players pl ON p.player_id = pl.id WHERE p.id = ? AND pl.club_id = ?').bind(id, (Astro.locals as any).clubId).first();
if (!payment) return Astro.redirect('/admin/payments');
---
<AdminLayout title={`Plată - ${payment.first_name} ${payment.last_name}`}>
  <a href="/admin/payments" style="color:#6b7280;font-size:14px;text-decoration:none;display:inline-flex;align-items:center;gap:6px;margin-bottom:20px">← Înapoi</a>
  <div class="card">
    <h2 style="font-size:16px;font-weight:700;margin-bottom:24px;color:#1e293b">{payment.first_name} {payment.last_name}</h2>
    <div style="display:grid;gap:16px">
      <div><label style="font-weight:700;color:#6b7280;font-size:12px;text-transform:uppercase">Sumă</label><p style="margin-top:4px;font-size:20px;font-weight:700;color:#1976C2">{payment.amount} RON</p></div>
      <div><label style="font-weight:700;color:#6b7280;font-size:12px;text-transform:uppercase">Status</label><p style="margin-top:4px"><span class="badge badge-{payment.status === 'PAID' ? 'green' : 'yellow'}">{payment.status === 'PAID' ? 'Plată' : 'Restant'}</span></p></div>
      <div><label style="font-weight:700;color:#6b7280;font-size:12px;text-transform:uppercase">Data</label><p style="margin-top:4px">{payment.due_date}</p></div>
    </div>
  </div>
</AdminLayout>
