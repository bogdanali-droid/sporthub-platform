---
import PlayerLayout from '@/layouts/PlayerLayout.astro';
import { queryFirst, queryAll } from '@/lib/db';

if (!Astro.locals.user) return Astro.redirect('/login');
const user = Astro.locals.user;
if (!['PLAYER', 'SUPERADMIN'].includes(user.role)) return Astro.redirect('/login');

const db = (Astro.locals as any).runtime?.env?.DB;

const player = await queryFirst<any>(db, 'SELECT * FROM players WHERE user_id=?', [user.id]);

let matches: any[] = [];
let stats = { acasa: 0, deplasare: 0, victorii: 0, infrangeri: 0, egaluri: 0 };

if (player) {
  matches = await queryAll<any>(db,
    `SELECT m.*, ms.position_played, ms.role
     FROM match_selections ms
     JOIN matches m ON m.id=ms.match_id
     WHERE ms.player_id=?
     ORDER BY m.match_date DESC
     LIMIT 40`,
    [player.id]
  );

  for (const m of matches) {
    if (m.is_home) stats.acasa++; else stats.deplasare++;
    if (m.score_home != null && m.score_away != null) {
      const sh = Number(m.score_home);
      const sa = Number(m.score_away);
      if (m.is_home) {
        if (sh > sa) stats.victorii++;
        else if (sh < sa) stats.infrangeri++;
        else stats.egaluri++;
      } else {
        if (sa > sh) stats.victorii++;
        else if (sa < sh) stats.infrangeri++;
        else stats.egaluri++;
      }
    }
  }
}

const matchStatusBadge: Record<string, string> = {
  FINISHED: 'badge-green',
  SCHEDULED: 'badge-blue',
  CANCELLED: 'badge-red',
  POSTPONED: 'badge-yellow',
};
const matchStatusLabel: Record<string, string> = {
  FINISHED: 'Finalizat',
  SCHEDULED: 'Programat',
  CANCELLED: 'Anulat',
  POSTPONED: 'Amânat',
};
---

<PlayerLayout title="Meciuri" user={user}>
  {!player ? (
    <div class="card" style="text-align:center;padding:48px 24px">
      <div style="font-size:48px;margin-bottom:16px">⚠️</div>
      <h2 style="color:#1e293b;margin-bottom:8px">Cont neconectat la un profil de jucător</h2>
      <p style="color:#64748b">Contactează administratorul clubului pentru a-ți lega contul de un profil de jucător.</p>
    </div>
  ) : (
    <div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:16px;margin-bottom:24px">
        <div class="stat-card">
          <div class="stat-value">{matches.length}</div>
          <div class="stat-label">Total meciuri</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{stats.acasa}</div>
          <div class="stat-label">Acasă</div>
        </div>
        <div class="stat-card">
          <div class="stat-value">{stats.deplasare}</div>
          <div class="stat-label">Deplasare</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" style="color:#166534">{stats.victorii}</div>
          <div class="stat-label">Victorii</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" style="color:#991b1b">{stats.infrangeri}</div>
          <div class="stat-label">Înfrângeri</div>
        </div>
        <div class="stat-card">
          <div class="stat-value" style="color:#854d0e">{stats.egaluri}</div>
          <div class="stat-label">Egaluri</div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <span class="card-title">Lista meciuri</span>
        </div>
        {matches.length === 0 ? (
          <p style="color:#94a3b8;font-size:14px">Nicio selecție înregistrată.</p>
        ) : (
          <table class="table">
            <thead>
              <tr>
                <th>Adversar</th>
                <th>Competiție</th>
                <th>Data</th>
                <th>Teren</th>
                <th>Scor</th>
                <th>Poziție</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              {matches.map(m => (
                <tr>
                  <td style="font-weight:500">
                    {m.is_home ? 'vs' : '@'} {m.opponent_name}
                  </td>
                  <td>{m.competition ?? '—'}</td>
                  <td>{m.match_date}</td>
                  <td>{m.location ?? '—'}</td>
                  <td>
                    {m.score_home != null
                      ? `${m.score_home} - ${m.score_away}`
                      : '—'
                    }
                  </td>
                  <td>{m.position_played ?? m.role ?? '—'}</td>
                  <td>
                    <span class={`badge ${matchStatusBadge[m.status] ?? 'badge-gray'}`}>
                      {matchStatusLabel[m.status] ?? m.status ?? '—'}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    </div>
  )}
</PlayerLayout>
