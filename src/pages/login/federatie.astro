---
import { loginPlatformUser } from '@/lib/auth';

const env = (Astro.locals as any).runtime?.env;
const db = env?.DB;
const kv = env?.SESSION_KV;

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = (form.get('email') as string)?.trim() ?? '';
  const password = (form.get('password') as string) ?? '';
  const ip = Astro.locals.clientIP;

  if (!email || !password) {
    error = 'Completează toate câmpurile.';
  } else {
    const result = await loginPlatformUser(db, kv, email, password, ip);
    if (result) {
      Astro.cookies.set('session', result.token, {
        httpOnly: true,
        secure: true,
        sameSite: 'lax',
        path: '/',
        maxAge: 7 * 24 * 60 * 60,
      });
      return Astro.redirect('/federatie-admin');
    } else {
      error = 'Email sau parolă incorectă. Dacă ai mai multe tentative eșuate, contul este blocat temporar.';
    }
  }
}
---

<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Portal FRBS — Autentificare</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: #001524;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .card {
      background: #fff;
      border-radius: 16px;
      padding: 48px 40px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 25px 60px rgba(0,0,0,0.4);
    }
    .logo {
      text-align: center;
      margin-bottom: 32px;
    }
    .logo-icon {
      font-size: 48px;
      display: block;
      margin-bottom: 8px;
    }
    .logo h1 {
      font-size: 20px;
      font-weight: 700;
      color: #001524;
      letter-spacing: -0.3px;
    }
    .logo p {
      font-size: 13px;
      color: #64748b;
      margin-top: 4px;
    }
    .badge {
      display: inline-block;
      background: #F4B400;
      color: #001524;
      font-size: 11px;
      font-weight: 700;
      padding: 3px 10px;
      border-radius: 20px;
      letter-spacing: 0.5px;
      margin-top: 8px;
    }
    .error {
      background: #fef2f2;
      border: 1px solid #fecaca;
      color: #dc2626;
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 14px;
      margin-bottom: 20px;
    }
    label {
      display: block;
      font-size: 13px;
      font-weight: 600;
      color: #374151;
      margin-bottom: 6px;
    }
    input {
      width: 100%;
      padding: 11px 14px;
      border: 1.5px solid #e5e7eb;
      border-radius: 8px;
      font-size: 15px;
      outline: none;
      transition: border-color 0.15s;
      margin-bottom: 18px;
    }
    input:focus { border-color: #001524; }
    button[type="submit"] {
      width: 100%;
      padding: 13px;
      background: #001524;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
      margin-top: 4px;
    }
    button[type="submit"]:hover { background: #002a4a; }
    .footer {
      text-align: center;
      margin-top: 28px;
      font-size: 13px;
      color: #9ca3af;
    }
    .footer a {
      color: #001524;
      text-decoration: none;
      font-weight: 500;
    }
    .footer a:hover { text-decoration: underline; }
    .divider {
      border: none;
      border-top: 1px solid #f1f5f9;
      margin: 20px 0;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <span class="logo-icon">⚾</span>
      <h1>Federația Română de<br/>Baseball și Softball</h1>
      <p>Portal CCLTC &amp; Administrație</p>
      <span class="badge">PORTAL FEDERAȚIE</span>
    </div>

    {error && <div class="error">{error}</div>}

    <form method="POST">
      <label for="email">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        placeholder="ccltc@frbs.ro"
        required
        autocomplete="email"
      />

      <label for="password">Parolă</label>
      <input
        type="password"
        id="password"
        name="password"
        placeholder="••••••••"
        required
        autocomplete="current-password"
      />

      <button type="submit">Autentificare →</button>
    </form>

    <hr class="divider" />

    <div class="footer">
      Ești admin de club? <a href="/login">Login Club →</a>
    </div>
  </div>
</body>
</html>
