---
import AsociatieLayout from '@/layouts/AsociatieLayout.astro';
if (!Astro.locals.user) return Astro.redirect('/login');
const user = Astro.locals.user;
if (!['ASSOCIATION_ADMIN','FEDERATION_ADMIN','SUPERADMIN'].includes(user.role)) return Astro.redirect('/login');
const db = (Astro.locals as any).runtime?.env?.DB;

import { queryAll, queryFirst } from '@/lib/db';

const assoc = await queryFirst<any>(db, 'SELECT * FROM associations WHERE id=?', [user.association_id]);
const filterSport = Astro.url.searchParams.get('sport') ?? assoc?.sport_code ?? '';

let where = 'WHERE is_active=1';
const params: any[] = [];
if (filterSport) { where += ' AND sport_code=?'; params.push(filterSport); }

const competitii = await queryAll<any>(db,
  `SELECT * FROM federation_competitions ${where} ORDER BY season DESC, name`,
  params);

const formatLabel: Record<string,string> = {
  LEAGUE: 'Ligă', CUP: 'Cupă', GROUPS_KNOCKOUT: 'Grupe + Eliminatorii'
};
---

<AsociatieLayout title="Competiții" user={{ ...user, association_name: assoc?.name }}>

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
    <div>
      <h1 style="font-size:20px;font-weight:700;color:#1e293b">Competiții Active</h1>
      <p style="font-size:13px;color:#64748b">Competiții federale Baseball5 &amp; Softball</p>
    </div>
    <span class="badge badge-gray" style="font-size:13px;padding:6px 12px">{competitii.length} competiții</span>
  </div>

  <form method="GET" style="display:flex;gap:10px;margin-bottom:16px">
    <select name="sport" class="form-select" style="width:180px" onchange="this.form.submit()">
      <option value="">Toate sporturile</option>
      <option value="BASEBALL5" selected={filterSport==='BASEBALL5'}>Baseball5</option>
      <option value="SOFTBALL" selected={filterSport==='SOFTBALL'}>Softball</option>
    </select>
  </form>

  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>Denumire</th><th>Sport</th><th>Sezon</th><th>Categorie vârstă</th><th>Format</th><th>Innings</th><th></th>
        </tr>
      </thead>
      <tbody>
        {competitii.length === 0 && (
          <tr><td colspan="7" style="text-align:center;color:#64748b;padding:24px">Nu există competiții active.</td></tr>
        )}
        {competitii.map((c: any) => (
          <tr>
            <td style="font-weight:500">
              <button
                class="btn btn-outline btn-sm"
                style="text-decoration:none;font-weight:600;color:#431407;border:none;padding:0;background:none;cursor:pointer"
                onclick={`openCompetitie('${c.id}', ${JSON.stringify(c.name)})`}
              >
                {c.name}
              </button>
            </td>
            <td><span class="badge badge-blue">{c.sport_code}</span></td>
            <td>{c.season}</td>
            <td><span class="badge badge-gray">{c.age_group ?? '—'}</span></td>
            <td>{formatLabel[c.format] ?? c.format ?? '—'}</td>
            <td style="text-align:center">{c.innings_count ?? '—'}</td>
            <td>
              <button class="btn btn-outline btn-sm" onclick={`openCompetitie('${c.id}', ${JSON.stringify(c.name)})`}>
                Detalii
              </button>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Modal detalii competiție -->
  <div class="modal-overlay" id="modal-competitie">
    <div class="modal" style="max-width:680px">
      <div class="modal-header">
        <span class="modal-title" id="modal-comp-title">Detalii competiție</span>
        <button class="modal-close" onclick="document.getElementById('modal-competitie').classList.remove('open')">✕</button>
      </div>
      <div class="modal-body" id="modal-comp-body">
        <p style="color:#64748b">Se încarcă...</p>
      </div>
      <div class="modal-footer">
        <button class="btn btn-outline" onclick="document.getElementById('modal-competitie').classList.remove('open')">Închide</button>
      </div>
    </div>
  </div>

</AsociatieLayout>

<script>
async function openCompetitie(id: string, name: string) {
  const overlay = document.getElementById('modal-competitie');
  const titleEl = document.getElementById('modal-comp-title');
  const bodyEl  = document.getElementById('modal-comp-body');
  if (!overlay || !titleEl || !bodyEl) return;

  titleEl.textContent = name;
  bodyEl.innerHTML = '<p style="color:#64748b">Se încarcă grupele...</p>';
  overlay.classList.add('open');

  try {
    const res = await fetch(`/api/asociatie-admin/competitii/groups?id=${encodeURIComponent(id)}`);
    const data = await res.json() as { groups: Array<{ id: string; name: string; teams_data: string | null }> };
    const groups = data.groups ?? [];

    if (groups.length === 0) {
      bodyEl.innerHTML = '<p style="color:#64748b;text-align:center;padding:16px 0">Nu există grupe înregistrate pentru această competiție.</p>';
      return;
    }

    let html = '';
    for (const g of groups) {
      html += `<div style="margin-bottom:20px"><h3 style="font-size:14px;font-weight:600;color:#1e293b;margin-bottom:8px">${g.name}</h3>`;
      const teams = (g.teams_data ?? '').split(',').filter(Boolean).map((t: string) => {
        const [team, wins, losses, points] = t.split(':');
        return { team, wins: wins ?? '0', losses: losses ?? '0', points: points ?? '0' };
      });
      if (teams.length === 0) {
        html += '<p style="color:#94a3b8;font-size:13px">Nicio echipă adăugată.</p>';
      } else {
        html += '<table style="width:100%;border-collapse:collapse;font-size:13px"><thead><tr style="border-bottom:2px solid #f1f5f9">';
        html += '<th style="text-align:left;padding:6px 8px;color:#64748b;font-size:11px;text-transform:uppercase">Echipă</th>';
        html += '<th style="text-align:center;padding:6px 8px;color:#64748b;font-size:11px;text-transform:uppercase">V</th>';
        html += '<th style="text-align:center;padding:6px 8px;color:#64748b;font-size:11px;text-transform:uppercase">Î</th>';
        html += '<th style="text-align:center;padding:6px 8px;color:#64748b;font-size:11px;text-transform:uppercase">Pct</th>';
        html += '</tr></thead><tbody>';
        for (const t of teams) {
          html += `<tr style="border-bottom:1px solid #f8fafc">`;
          html += `<td style="padding:8px;font-weight:500">${t.team}</td>`;
          html += `<td style="text-align:center;padding:8px">${t.wins}</td>`;
          html += `<td style="text-align:center;padding:8px">${t.losses}</td>`;
          html += `<td style="text-align:center;padding:8px;font-weight:600">${t.points}</td>`;
          html += '</tr>';
        }
        html += '</tbody></table>';
      }
      html += '</div>';
    }
    bodyEl.innerHTML = html;
  } catch {
    bodyEl.innerHTML = '<p style="color:#991b1b">Eroare la încărcarea datelor.</p>';
  }
}
(window as any).openCompetitie = openCompetitie;
</script>
