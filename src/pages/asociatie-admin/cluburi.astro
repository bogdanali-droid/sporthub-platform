---
import AsociatieLayout from '@/layouts/AsociatieLayout.astro';
if (!Astro.locals.user) return Astro.redirect('/login');
const user = Astro.locals.user;
if (!['ASSOCIATION_ADMIN','FEDERATION_ADMIN','SUPERADMIN'].includes(user.role)) return Astro.redirect('/login');
const db = (Astro.locals as any).runtime?.env?.DB;

import { queryAll, queryFirst } from '@/lib/db';

const assoc = await queryFirst<any>(db, 'SELECT * FROM associations WHERE id=?', [user.association_id]);
const filterSport = Astro.url.searchParams.get('sport') ?? '';

let where = 'WHERE c.association_id=?';
const params: any[] = [user.association_id];
if (filterSport) { where += ' AND c.sport_code=?'; params.push(filterSport); }

const cluburi = await queryAll<any>(db,
  `SELECT c.*, COUNT(DISTINCT p.id) AS player_count
   FROM clubs c LEFT JOIN players p ON p.club_id=c.id
   ${where}
   GROUP BY c.id ORDER BY c.name`,
  params);
---

<AsociatieLayout title="Cluburi" user={{ ...user, association_name: assoc?.name }}>

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
    <div>
      <h1 style="font-size:20px;font-weight:700;color:#1e293b">Cluburi</h1>
      <p style="font-size:13px;color:#64748b">Cluburile afiliate asociației</p>
    </div>
    <span class="badge badge-gray" style="font-size:13px;padding:6px 12px">{cluburi.length} cluburi</span>
  </div>

  <div class="alert alert-warning" style="margin-bottom:16px">
    Înregistrarea cluburilor noi se face prin SUPERADMIN. Puteți activa sau dezactiva cluburile existente.
  </div>

  <form method="GET" style="display:flex;gap:10px;margin-bottom:16px">
    <select name="sport" class="form-select" style="width:180px" onchange="this.form.submit()">
      <option value="">Toate sporturile</option>
      <option value="BASEBALL5" selected={filterSport==='BASEBALL5'}>Baseball5</option>
      <option value="SOFTBALL" selected={filterSport==='SOFTBALL'}>Softball</option>
    </select>
  </form>

  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>Nume club</th><th>Sport</th><th>Email</th><th>Telefon</th>
          <th style="text-align:center">Jucători</th><th>Status</th><th>Acțiuni</th>
        </tr>
      </thead>
      <tbody>
        {cluburi.length === 0 && (
          <tr><td colspan="7" style="text-align:center;color:#64748b;padding:24px">Nu există cluburi în această asociație.</td></tr>
        )}
        {cluburi.map((c: any) => (
          <tr id={`row-${c.id}`}>
            <td style="font-weight:500;color:#1e293b">{c.name}</td>
            <td><span class="badge badge-blue">{c.sport_code}</span></td>
            <td style="font-size:12px;color:#64748b">{c.contact_email ?? '—'}</td>
            <td style="font-size:12px;color:#64748b">{c.contact_phone ?? '—'}</td>
            <td style="text-align:center;font-weight:600">{c.player_count}</td>
            <td>
              <span class={`badge ${c.is_active ? 'badge-green' : 'badge-gray'}`} id={`badge-${c.id}`}>
                {c.is_active ? 'Activ' : 'Inactiv'}
              </span>
            </td>
            <td>
              <button
                class="btn btn-outline btn-sm"
                id={`btn-${c.id}`}
                onclick={`toggleClub('${c.id}', ${c.is_active ? 0 : 1})`}
              >
                {c.is_active ? 'Dezactivează' : 'Activează'}
              </button>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

</AsociatieLayout>

<script>
async function toggleClub(clubId: string, newActive: number) {
  const btn = document.getElementById(`btn-${clubId}`) as HTMLButtonElement;
  const badge = document.getElementById(`badge-${clubId}`);
  if (!btn || !badge) return;

  btn.disabled = true;
  btn.textContent = 'Se procesează...';

  try {
    const res = await fetch('/api/asociatie-admin/clubs/toggle', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ club_id: clubId, is_active: newActive }),
    });
    const data = await res.json() as { ok: boolean; is_active: number };
    if (data.ok) {
      const active = data.is_active === 1;
      badge.textContent = active ? 'Activ' : 'Inactiv';
      badge.className = `badge ${active ? 'badge-green' : 'badge-gray'}`;
      btn.textContent = active ? 'Dezactivează' : 'Activează';
      btn.onclick = () => toggleClub(clubId, active ? 0 : 1);
    } else {
      btn.textContent = 'Eroare';
    }
  } catch {
    btn.textContent = 'Eroare rețea';
  } finally {
    btn.disabled = false;
  }
}
(window as any).toggleClub = toggleClub;
</script>
