---
import FederatieLayout from '@/layouts/FederatieLayout.astro';
if (!Astro.locals.user) return Astro.redirect('/login/federatie');
const user = Astro.locals.user;
if (!['FEDERATION_ADMIN','SUPERADMIN'].includes(user.role)) return Astro.redirect('/login/federatie');
const db = (Astro.locals as any).runtime?.env?.DB;
import { queryAll } from '@/lib/db';

const msg = Astro.url.searchParams.get('msg');
const err = Astro.url.searchParams.get('err');

const suspendati = await queryAll<any>(db,
  `SELECT p.id, p.first_name, p.last_name, pl.license_number, pl.sport_code,
          pl.valid_until, c.name AS club_name
   FROM players p
   JOIN player_legitimations pl ON pl.player_id = p.id
   LEFT JOIN clubs c ON c.id = p.club_id
   WHERE pl.status = 'SUSPENDED'
   ORDER BY p.last_name`, []);
---

<FederatieLayout title="Suspendări" user={user} section="CCLTC">

  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
    <div>
      <h1 style="font-size:20px;font-weight:700;color:#1e293b">Jucători Suspendați</h1>
      <p style="font-size:13px;color:#64748b">Gestionare suspendări disciplinare Baseball5 &amp; Softball</p>
    </div>
    <button class="btn btn-gold" onclick="document.getElementById('modal-suspend').classList.add('open')">+ Suspendare nouă</button>
  </div>

  {msg === 'suspendat' && <div class="alert alert-success">Jucătorul a fost suspendat cu succes.</div>}
  {err === 'date-lipsa' && <div class="alert alert-error">Completează toate câmpurile obligatorii.</div>}
  {err === 'jucator-negasit' && <div class="alert alert-error">Jucătorul specificat nu a fost găsit în baza de date.</div>}

  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>Jucător</th><th>Club</th><th>Sport</th><th>Licență</th><th>Status</th>
        </tr>
      </thead>
      <tbody>
        {suspendati.length === 0 && (
          <tr>
            <td colspan="5" style="text-align:center;color:#64748b;padding:32px">
              Nu există jucători suspendați în prezent.
            </td>
          </tr>
        )}
        {suspendati.map((p: any) => (
          <tr>
            <td style="font-weight:500">{p.last_name} {p.first_name}</td>
            <td style="font-size:13px;color:#475569">{p.club_name ?? <em style="color:#94a3b8">—</em>}</td>
            <td><span class="badge badge-blue">{p.sport_code}</span></td>
            <td style="font-family:monospace;font-size:12px">{p.license_number ?? '—'}</td>
            <td><span class="badge badge-red">Suspendat</span></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Modal suspendare jucător -->
  <div class="modal-overlay" id="modal-suspend">
    <div class="modal">
      <div class="modal-header">
        <span class="modal-title">Suspendare jucător</span>
        <button class="modal-close" onclick="document.getElementById('modal-suspend').classList.remove('open')">✕</button>
      </div>
      <form method="POST" action="/api/federatie-admin/suspendari/suspend">
        <div class="modal-body">
          <div class="form-group">
            <label class="form-label">ID Jucător (UUID) *</label>
            <input type="text" name="player_id" class="form-input" required
              placeholder="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx" />
            <p style="font-size:12px;color:#64748b;margin-top:4px">Găsești ID-ul jucătorului în registrul național de jucători.</p>
          </div>
          <div class="form-group">
            <label class="form-label">Motiv suspendare</label>
            <textarea name="reason" class="form-textarea" rows="3"
              placeholder="ex. Comportament antisportiv în meciul din 15.04.2025..."></textarea>
          </div>
          <div class="form-group">
            <label class="form-label">Durată (zile)</label>
            <input type="number" name="duration_days" class="form-input" min="1" max="365"
              placeholder="ex. 30" />
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline" onclick="document.getElementById('modal-suspend').classList.remove('open')">Anulează</button>
          <button type="submit" class="btn btn-gold" onclick="return confirm('Ești sigur că vrei să suspendezi acest jucător?')">Aplică suspendare</button>
        </div>
      </form>
    </div>
  </div>

</FederatieLayout>
