---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';

const user = (Astro.locals as any).user;
if (!user) return Astro.redirect('/login');
if (user.role !== 'SUPERADMIN') return Astro.redirect('/admin');

const db = (Astro.locals as any).runtime?.env?.DB;
const msg = Astro.url.searchParams.get('msg');
const err = Astro.url.searchParams.get('err');

let associations: any[] = [];
try {
  const res = await db?.prepare(`
    SELECT a.*, f.name as federation_name, f.acronym as federation_acronym,
           (SELECT COUNT(*) FROM clubs c WHERE c.association_id = a.id) as club_count
    FROM associations a
    LEFT JOIN federations f ON f.id = a.federation_id
    ORDER BY a.name
  `).all();
  associations = res?.results ?? [];
} catch {}

let federations: any[] = [];
try {
  const res = await db?.prepare('SELECT id, name, acronym FROM federations ORDER BY name').all();
  federations = res?.results ?? [];
} catch {}
---
<AdminLayout title="Asociații">
  {msg === 'creat' && <div class="alert alert-success" style="margin-bottom:16px">Asociația a fost creată.</div>}
  {err === 'date' && <div class="alert alert-error" style="margin-bottom:16px">Numele și federația sunt obligatorii.</div>}

  <div style="margin-bottom:20px">
    <h2 style="font-size:20px;font-weight:800;margin-bottom:4px">Asociații</h2>
    <p style="color:#6b7280;font-size:13px">Asociații județene / municipale sub federații.</p>
  </div>

  <div class="card" style="padding:0;overflow:hidden;margin-bottom:24px">
    {associations.length === 0 ? (
      <div style="padding:40px 24px;text-align:center;color:#9ca3af"><p>Nicio asociație înregistrată.</p></div>
    ) : (
      <table class="table">
        <thead><tr><th>Nume</th><th>Acronim</th><th>Regiune</th><th>Federație</th><th>Cluburi</th><th>Status</th></tr></thead>
        <tbody>
          {associations.map((a: any) => (
            <tr>
              <td style="font-weight:700">
                <a href={`/superadmin/associations/${a.id}`} style="color:#0f172a;text-decoration:none">{a.name}</a>
              </td>
              <td><span class="badge badge-blue">{a.acronym || '—'}</span></td>
              <td>{a.region || '—'}</td>
              <td style="font-size:13px;color:#6b7280">{a.federation_acronym || a.federation_name || '—'}</td>
              <td><span style="font-weight:700;color:#7c3aed">{a.club_count}</span></td>
              <td>{a.is_active ? <span class="badge badge-green">Activ</span> : <span class="badge badge-red">Inactiv</span>}</td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <div class="card" style="max-width:560px">
    <h3 style="font-size:15px;font-weight:700;margin-bottom:16px">+ Asociație nouă</h3>
    <form method="POST" action="/api/superadmin/associations">
      <div class="form-group">
        <label class="form-label">Federație *</label>
        <select name="federation_id" class="form-select" required>
          <option value="">-- alege federația --</option>
          {federations.map((f: any) => (
            <option value={f.id}>{f.acronym || f.name}</option>
          ))}
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Nume *</label>
        <input type="text" name="name" class="form-input" required placeholder="Asociația Municipală..." />
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div class="form-group">
          <label class="form-label">Acronim</label>
          <input type="text" name="acronym" class="form-input" placeholder="AMRB" />
        </div>
        <div class="form-group">
          <label class="form-label">Regiune</label>
          <input type="text" name="region" class="form-input" placeholder="București" />
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-input" />
      </div>
      <button type="submit" class="btn btn-primary">Creează</button>
    </form>
  </div>
</AdminLayout>
