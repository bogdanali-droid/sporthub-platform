---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';

const user = (Astro.locals as any).user;
if (!user) return Astro.redirect('/login');
if (user.role !== 'SUPERADMIN') return Astro.redirect('/admin');

const { id } = Astro.params;
const db = (Astro.locals as any).runtime?.env?.DB;
const msg = Astro.url.searchParams.get('msg');
const err = Astro.url.searchParams.get('err');

const assoc = await db?.prepare(`
  SELECT a.*, f.name as federation_name, f.acronym as federation_acronym
  FROM associations a LEFT JOIN federations f ON f.id = a.federation_id
  WHERE a.id = ?
`).bind(id).first() as any;

if (!assoc) return Astro.redirect('/superadmin/associations');

const memberClubsRes = await db?.prepare(`
  SELECT c.id, c.name, c.city, c.sport_code, c.is_active,
         (SELECT COUNT(*) FROM players p WHERE p.club_id = c.id) as player_count
  FROM clubs c WHERE c.association_id = ? ORDER BY c.name
`).bind(id).all();
const memberClubs = memberClubsRes?.results ?? [];

const availableClubsRes = await db?.prepare(`
  SELECT id, name, city, sport_code FROM clubs
  WHERE (association_id IS NULL OR association_id != ?) AND is_active = 1
  ORDER BY name
`).bind(id).all();
const availableClubs = availableClubsRes?.results ?? [];
---
<AdminLayout title={`${assoc.acronym || assoc.name}`}>
  {msg === 'asignat' && <div class="alert alert-success" style="margin-bottom:16px">Clubul a fost asignat.</div>}
  {msg === 'eliminat' && <div class="alert alert-success" style="margin-bottom:16px">Clubul a fost eliminat din asociație.</div>}
  {err === 'club' && <div class="alert alert-error" style="margin-bottom:16px">Selectează un club.</div>}

  <div style="margin-bottom:20px">
    <a href="/superadmin/associations" style="color:#6b7280;text-decoration:none;font-size:13px">← Toate asociațiile</a>
  </div>

  <div class="card" style="margin-bottom:24px">
    <div style="display:flex;align-items:center;gap:16px">
      <div style="width:52px;height:52px;border-radius:12px;background:linear-gradient(135deg,#3b82f6,#1d4ed8);display:flex;align-items:center;justify-content:center;font-size:22px">🗺️</div>
      <div>
        <h2 style="font-size:22px;font-weight:900">{assoc.name}</h2>
        <p style="font-size:13px;color:#6b7280">
          {assoc.acronym && <span class="badge badge-blue" style="margin-right:8px">{assoc.acronym}</span>}
          {assoc.region && <span>{assoc.region}</span>}
          {assoc.federation_acronym && <span> · {assoc.federation_acronym}</span>}
        </p>
      </div>
    </div>
    {(assoc.email || assoc.phone) && (
      <div style="display:flex;gap:16px;margin-top:12px;font-size:13px;color:#6b7280">
        {assoc.email && <span>✉️ {assoc.email}</span>}
        {assoc.phone && <span>📞 {assoc.phone}</span>}
      </div>
    )}
  </div>

  <div class="card" style="padding:0;overflow:hidden;margin-bottom:24px">
    <div style="padding:18px 24px;border-bottom:1px solid #f0f1f3">
      <h3 style="font-size:16px;font-weight:800">Cluburi membre ({memberClubs.length})</h3>
    </div>
    {memberClubs.length === 0 ? (
      <div style="padding:40px 24px;text-align:center;color:#9ca3af"><p>Niciun club asignat.</p></div>
    ) : (
      <table class="table">
        <thead><tr><th>Nume</th><th>Sport</th><th>Oraș</th><th>Jucători</th><th>Status</th><th></th></tr></thead>
        <tbody>
          {(memberClubs as any[]).map((c: any) => (
            <tr>
              <td style="font-weight:700">{c.name}</td>
              <td style="color:#6b7280">{c.sport_code || '—'}</td>
              <td style="color:#6b7280">{c.city || '—'}</td>
              <td><span style="font-weight:700;color:#7c3aed">{c.player_count}</span></td>
              <td>{c.is_active ? <span class="badge badge-green">Activ</span> : <span class="badge badge-red">Inactiv</span>}</td>
              <td style="text-align:right">
                <form method="POST" action={`/api/superadmin/associations/${id}/clubs/${c.id}`} style="display:inline">
                  <button type="submit" class="btn btn-danger btn-sm" onclick={`return confirm('Elimini ${c.name}?')`}>Elimină</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <div class="card" style="max-width:560px">
    <h3 style="font-size:15px;font-weight:700;margin-bottom:12px">+ Adaugă club</h3>
    {availableClubs.length === 0 ? (
      <p style="color:#9ca3af;font-size:13px">Toate cluburile active sunt deja asignate.</p>
    ) : (
      <form method="POST" action={`/api/superadmin/associations/${id}/clubs`}>
        <div class="form-group">
          <select name="club_id" class="form-select" required>
            <option value="">-- alege clubul --</option>
            {(availableClubs as any[]).map((c: any) => (
              <option value={c.id}>{c.name}{c.city ? ` (${c.city})` : ''} — {c.sport_code}</option>
            ))}
          </select>
        </div>
        <button type="submit" class="btn btn-primary">Asignează</button>
      </form>
    )}
  </div>
</AdminLayout>
